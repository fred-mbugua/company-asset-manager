<%- include('partials/header', { pageTitle: 'Asset Report', cssFile: 'assets-report' }) %>
<!-- Select2 CSS -->
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<%- include('partials/navbar', { user: locals.user }) %>

<div class="main">
  <%- include('partials/sidebar') %>
  <section class="content-area">
    <div class="assets-container" id="assets-list-section">
      <h3>Asset Report</h3>

      <div class="filters">
        <div class="filter-row">
          <div class="filter-group">
            <label for="filter-type">Asset Type:</label>
            <select id="filter-type" class="select2-dropdown">
              <option value="">All Types</option>
              <% if (locals.assetTypes) { %>
              <% locals.assetTypes.forEach(type => { %>
              <option value="<%= type.name %>" data-type-id="<%= type.id %>"><%= type.name %></option>
              <% }); %>
              <% } %>
            </select>
          </div>
          
          <div class="filter-group">
            <label for="filter-location">Location:</label>
            <select id="filter-location" class="select2-dropdown">
              <option value="">All Locations</option>
              <% if (locals.branches) { %>
              <% locals.branches.forEach(location => { %>
              <option value="<%= location.name %>" data-location-id="<%= location.id %>"><%= location.name %></option>
              <% }); %>
              <% } %>
            </select>
          </div>
          
          <div class="filter-group">
            <label for="filter-status">Status:</label>
            <select id="filter-status" class="select2-dropdown">
              <option value="">All Statuses</option>
              <% if (locals.assetStatuses) { %>
              <% locals.assetStatuses.forEach(status => { %>
              <option value="<%= status.name %>" data-status-id="<%= status.id %>"><%= status.name %></option>
              <% }); %>
              <% } %>
            </select>
          </div>
        </div>
        
        <div class="filter-row">
          <div class="filter-group date-range">
            <label>Purchase Date Range:</label>
            <div class="date-inputs">
              <input type="date" id="filter-from-date" placeholder="From Date">
              <span class="date-separator">to</span>
              <input type="date" id="filter-to-date" placeholder="To Date">
            </div>
          </div>
          
          <div class="filter-actions">
            <button class="btn btn-view" id="search-btn">Search</button>
            <button class="btn btn-export" id="export-btn">Export to Excel</button>
          </div>
        </div>
      </div>

      <div class="report-table-wrapper">
        <table class="report-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Asset Tag</th>
              <th>Type</th>
              <th>Manufacturer</th>
              <th>Model</th>
              <th>Serial</th>
              <th>Status</th>
              <th>Location</th>
              <th>Purchase Date</th>
              <th>Purchase Amount</th>
            </tr>
          </thead>
          <tbody id="asset-table-body">
            <!-- Asset rows will be populated here dynamically -->
            <% if (locals.assets) { %>
            <% locals.assets.forEach(asset => { %>
            <tr>
              <td><%= asset.id %></td>
              <td><%= asset.asset_tag %></td>
              <td><%= asset.type_name %></td>
              <td><%= asset.manufacturer %></td>
              <td><%= asset.model %></td>
              <td><%= asset.serial_number %></td>
              <td><%= asset.status_name %></td>
              <td><%= asset.location %></td>
              <td><span data-date="<%= asset.purchase_date %>"></span></td>
              <td>Ksh. <%= asset.purchase_price ? parseFloat(asset.purchase_price).toLocaleString() : '0' %></td>
            </tr>
            <% }); %>
            <% } %>
          </tbody>
        </table>

        

      </div>

      <div class="pagination-controls">
          <div class="pagination-info">
              <select id="page-size">
                <option value="20">20 per page</option>
                <option value="30">30 per page</option>
                <option value="50">50 per page</option>
              </select>
              <span id="page-info">Page <%= pagination.currentPage %> of <%= pagination.totalPages %> (<%= totalAssets %> total)</span>
          </div>
          <div class="pagination-buttons">
              <button id="prev-btn" class="btn btn-page" <%= pagination.hasPrevPage ? '' : 'disabled' %> title="Previous Page">
                  <i class="fa fa-chevron-left"></i>
              </button>
              <button id="next-btn" class="btn btn-page" <%= pagination.hasNextPage ? '' : 'disabled' %> title="Next Page">
                  <i class="fa fa-chevron-right"></i>
              </button>
          </div>
        </div>
    </div>

  </section>
</div>

<!-- jQuery (required for Select2) -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<!-- Select2 JS -->
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script>
$(document).ready(function() {
    $('.select2-dropdown').select2({
        placeholder: 'Select an option',
        allowClear: true,
        width: 'style',
        minimumResultsForSearch: 0
    });
});
</script>

<%- include('partials/footer', { jsFile: 'assets-report' }) %>