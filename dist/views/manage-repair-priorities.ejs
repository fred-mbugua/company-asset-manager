<%- include('partials/header', { pageTitle: 'Manage Repair Request Priorities', cssFile: 'manage-repair-priorities' }) %>
<%- include('partials/navbar', { user: locals.user }) %>

<div class="main">
    <%- include('partials/sidebar') %>
    <section class="content-area">
        <div class="management-container">
            <div class="page-header">
                <div class="header-left">
                    <h3><i class="uil uil-sort-amount-up"></i> Repair Request Priority Management</h3>
                    <p class="subtitle">Configure priority levels for repair requests</p>
                </div>
                <div class="header-right">
                    <button id="add-priority-btn" class="btn btn-add">
                        <i class="uil uil-plus"></i> Add New Priority
                    </button>
                </div>
            </div>

            <div id="priority-form-modal" class="modal">
                <div class="modal-content">
                    <span class="close-btn">&times;</span>
                    <h4><i class="uil uil-edit"></i> <span id="modal-title">Add New Priority</span></h4>
                    
                    <form id="priority-form">
                        <input type="hidden" id="priority-id" name="id">

                        <div class="form-group">
                            <label for="name">Priority Name:<span class="required">*</span></label>
                            <input type="text" id="name" name="name" required placeholder="e.g., High">
                        </div>

                        <div class="form-group">
                            <label for="description">Description:</label>
                            <textarea id="description" name="description" rows="3" placeholder="Brief description of this priority level..."></textarea>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label for="color_code">Color Code:</label>
                                <div class="color-input-group">
                                    <input type="color" id="color_picker" value="#f39c12">
                                    <input type="text" id="color_code" name="color_code" value="#f39c12" placeholder="#f39c12">
                                </div>
                            </div>
                            <div class="form-group">
                                <label for="display_order">Display Order:</label>
                                <input type="number" id="display_order" name="display_order" min="0" value="0">
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label for="is_active">Active Status:</label>
                                <select id="is_active" name="is_active">
                                    <option value="true">Active</option>
                                    <option value="false">Inactive</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Priority Preview:</label>
                                <span id="priority-preview" class="priority-badge" style="background-color: #f39c12;">Preview</span>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary mt-3">
                            <i class="uil uil-save"></i> Save Priority
                        </button>
                    </form>
                </div>
            </div>
            
            <div class="list-section mt-4">
                <div class="search-filter-section mb-3">
                    <input type="text" id="search-input" placeholder="Search priorities..." class="search-input">
                    <label class="checkbox-label">
                        <input type="checkbox" id="show-inactive" checked>
                        <span>Show Inactive</span>
                    </label>
                </div>

                <table id="priorities-table" class="data-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Description</th>
                            <th>Preview</th>
                            <th>Order</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="priorities-table-body">
                        <% if (locals.repairPriorities && locals.repairPriorities.length > 0) { %>
                            <% locals.repairPriorities.forEach(priority => { %>
                                <tr data-priority-id="<%= priority.id %>" class="<%= !priority.is_active ? 'row-inactive' : '' %>">
                                    <td data-label="ID"><%= priority.id %></td>
                                    <td data-label="Name"><%= priority.name %></td>
                                    <td data-label="Description"><%= priority.description || 'N/A' %></td>
                                    <td data-label="Preview">
                                        <span class="priority-badge" style="background-color: <%= priority.color_code || '#6c757d' %>;">
                                            <%= priority.name %>
                                        </span>
                                    </td>
                                    <td data-label="Order"><%= priority.display_order || 0 %></td>
                                    <td data-label="Status">
                                        <span class="status-badge <%= priority.is_active ? 'status-active' : 'status-inactive' %>">
                                            <%= priority.is_active ? 'Active' : 'Inactive' %>
                                        </span>
                                    </td>
                                    <td data-label="Actions">
                                        <button class="btn btn-sm btn-edit" data-id="<%= priority.id %>" title="Edit">
                                            <i class="uil uil-edit"></i>
                                        </button>
                                        <button class="btn btn-sm btn-toggle" data-id="<%= priority.id %>" data-active="<%= priority.is_active %>" title="<%= priority.is_active ? 'Deactivate' : 'Activate' %>">
                                            <i class="uil <%= priority.is_active ? 'uil-toggle-on' : 'uil-toggle-off' %>"></i>
                                        </button>
                                        <button class="btn btn-sm btn-delete" data-id="<%= priority.id %>" title="Delete">
                                            <i class="uil uil-trash-alt"></i>
                                        </button>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr>
                                <td colspan="7" style="text-align:center;">No repair request priorities found.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
                
                <div class="pagination-controls">
                    <div class="pagination-info">
                        <span id="page-info">Showing all records</span>
                    </div>
                </div>
            </div>

        </div>
    </section>
</div>

<%- include('partials/footer', { jsFile: 'manage-repair-priorities' }) %>
