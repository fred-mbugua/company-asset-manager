<%- include('partials/header', { pageTitle: 'Manage Asset Statuses', cssFile: 'manage-asset-statuses' }) %>
<%- include('partials/navbar', { user: locals.user }) %>

<div class="main">
    <%- include('partials/sidebar') %>
    <section class="content-area">
        <div class="management-container">
            <h3>Asset Status Management</h3>
            
            <button id="add-status-btn" class="btn btn-add">
                <i class="uil-plus"></i> Add New Asset Status
            </button>

            <div id="status-form-modal" class="modal">
                <div class="modal-content">
                    <span class="close-btn">&times;</span>
                    <h4><span id="modal-title">Add New Asset Status</span></h4>
                    
                    <form id="status-form">
                        <input type="hidden" id="status-id" name="id">

                        <label for="name">Status Name:<span class="required">*</span></label>
                        <input type="text" id="name" name="name" required>

                        <label for="is_available">Is Available:</label>
                        <select id="is_available" name="is_available">
                            <option value="false">No</option>
                            <option value="true">Yes</option>
                        </select>

                        <label for="description">Description:</label>
                        <textarea id="description" name="description" rows="3"></textarea>

                        <button type="submit" class="btn btn-primary mt-3">
                            <i class="uil-save"></i> Save Status
                        </button>
                    </form>
                </div>
            </div>
            
            <div class="list-section mt-5">
                <h4>Existing Asset Statuses</h4>
                
                <div class="search-filter-section mb-3">
                    <input type="text" id="search-input" placeholder="Search by name..." class="search-input">
                </div>

                <table id="statuses-table" class="data-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Is Available</th>
                            <th>Description</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="statuses-table-body">
                        <% if (locals.assetStatuses && locals.assetStatuses.length > 0) { %>
                            <% locals.assetStatuses.forEach(status => { %>
                                <tr data-status-id="<%= status.id %>">
                                    <td data-label="ID"><%= status.id %></td>
                                    <td data-label="Name"><%= status.name %></td>
                                    <td data-label="Is Available"><%= status.is_available ? 'Yes' : 'No' %></td>
                                    <td data-label="Description"><%= status.description || 'N/A' %></td>
                                    <td data-label="Actions">
                                        <button class="btn btn-sm btn-edit" data-id="<%= status.id %>">Edit</button>
                                        <button class="btn btn-sm btn-delete" data-id="<%= status.id %>">Delete</button>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr>
                                <td colspan="5" style="text-align:center;">No asset statuses found.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
                
                <div class="pagination-controls">
                    <div class="pagination-info">
                        <select id="page-size">
                            <option value="10" selected>10 per page</option>
                            <option value="20">20 per page</option>
                            <option value="50">50 per page</option>
                        </select>
                        <span id="page-info">Page 1 of 1 (0 total)</span>
                    </div>
                    <div class="pagination-buttons">
                        <button id="prev-btn" class="btn btn-page" disabled title="Previous Page">
                            <i class="fa fa-chevron-left"></i>
                        </button>
                        <button id="next-btn" class="btn btn-page" disabled title="Next Page">
                            <i class="fa fa-chevron-right"></i>
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </section>
</div>

<%- include('partials/footer', { jsFile: 'manage-asset-statuses' }) %>
