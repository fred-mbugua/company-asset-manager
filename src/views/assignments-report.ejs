<%- include('partials/header', { pageTitle: 'Assignment Report', cssFile: 'assign-report' }) %>
<!-- Select2 CSS -->
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<%- include('partials/navbar', { user: locals.user }) %>

<div class="main">
    <%- include('partials/sidebar') %>
    <section class="content-area">
        <div class="report-container">
            <h3>Asset Assignments Report</h3>

            <div class="filters">
                <div class="filter-row">
                    <div class="filter-group">
                        <label for="filter-tag">Asset Tag:</label>
                        <select id="filter-tag" class="select2-dropdown">
                            <option value="">All Tags</option>
                            <% if (locals.assetTags && locals.assetTags.length) { %>
                                <% locals.assetTags.forEach(tag => { %>
                                    <option value="<%= tag %>"><%= tag %></option>
                                <% }); %>
                            <% } %>
                        </select>
                    </div>
                    
                    <div class="filter-group">
                        <label for="filter-department">Department:</label>
                        <select id="filter-department" class="select2-dropdown">
                            <option value="">All Departments</option>
                            <% if (locals.departments && locals.departments.length) { %>
                                <% locals.departments.forEach(dept => { %>
                                    <option value="<%= dept.name %>"><%= dept.name %></option>
                                <% }); %>
                            <% } %>
                        </select>
                    </div>
                    
                    <div class="filter-group">
                        <label for="filter-employee">Employee:</label>
                        <select id="filter-employee" class="select2-dropdown">
                            <option value="">All Employees</option>
                            <% if (locals.employees && locals.employees.length) { %>
                                <% locals.employees.forEach(employee => { %>
                                    <option value="<%= employee %>"><%= employee %></option>
                                <% }); %>
                            <% } %>
                        </select>
                    </div>
                    
                    <div class="filter-group">
                        <label for="filter-location">Location:</label>
                        <select id="filter-location" class="select2-dropdown">
                            <option value="">All Branches</option>
                            <% if (locals.locations && locals.locations.length) { %>
                                <% locals.locations.forEach(loc => { %>
                                    <option value="<%= loc.name %>"><%= loc.name %></option>
                                <% }); %>
                            <% } %>
                        </select>
                    </div>
                </div>
                
                <div class="filter-row">
                    <div class="filter-group date-range">
                        <label>Date Range:</label>
                        <div class="date-inputs">
                            <input type="date" id="filter-from-date" placeholder="From Date">
                            <span class="date-separator">to</span>
                            <input type="date" id="filter-to-date" placeholder="To Date">
                        </div>
                    </div>
                    
                    <div class="filter-actions">
                        <button class="btn btn-view" id="search-btn">Search</button>
                        <button class="btn btn-export" id="export-btn">Export to Excel</button>
                    </div>
                </div>
            </div>

            <div class="table-wrapper">
                <table class="report-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Asset Tag</th>
                            <th>Manufacturer</th>
                            <th>Model Name</th>
                            <th>Purchase Amount</th>
                            <th>Employee</th>
                            <th>Company</th>
                            <th>Department</th>
                            <th>Location</th>
                            <th>Assigned Date</th>
                            <th>Notes</th>
                            <th>Return Date</th>
                        </tr>
                    </thead>
                    <tbody id="assignments-table-body">
                        <% if (locals.initialAssignments && locals.initialAssignments.length > 0) { %>
                            <% locals.initialAssignments.forEach(assignment => { %>
                                <tr>
                                    <td><%= assignment.id %></td>
                                    <td><%= assignment.asset_tag %></td>
                                    <td><%= assignment.manufacturer %></td>
                                    <td><%= assignment.model %></td>
                                    <td>Ksh. <%= assignment.purchase_price ? parseFloat(assignment.purchase_price).toLocaleString() : '0' %></td>
                                    <td><%= assignment.employee_name %></td>
                                    <td><%= assignment.company || 'N/A' %></td>
                                    <td><%= assignment.department %></td>
                                    <td><%= assignment.location || 'N/A' %></td>
                                    <td><span data-date="<%= assignment.assignment_date %>"></span></td>
                                    <td title="<%= assignment.notes || '' %>"><%= assignment.notes ? assignment.notes.substring(0, 50) + '...' : 'N/A' %></td>
                                    <td><% if (assignment.return_date != null) { %><span data-date="<%= assignment.return_date %>"></span><% } else { %>N/A<% } %></td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr>
                                <td colspan="12" style="text-align:center;color:#888;">No assignments found.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>

            <div class="pagination-controls">
                <div class="pagination-info">
                    <select id="page-size">
                        <option value="20" <%= locals.pagination.itemsPerPage === 20 ? 'selected' : '' %>>20 per page</option>
                        <option value="30" <%= locals.pagination.itemsPerPage === 30 ? 'selected' : '' %>>30 per page</option>
                        <option value="50" <%= locals.pagination.itemsPerPage === 50 ? 'selected' : '' %>>50 per page</option>
                    </select>
                    <span id="page-info">Page <%= locals.pagination.currentPage %> of <%= locals.pagination.totalPages %> (<%= locals.totalAssignments %> total)</span>
                </div>
                <div class="pagination-buttons">
                    <button id="prev-btn" class="btn btn-page" <%= locals.pagination.currentPage === 1 ? 'disabled' : '' %> title="Previous Page">
                        <i class="fa fa-chevron-left"></i>
                    </button>
                    <button id="next-btn" class="btn btn-page" <%= locals.pagination.currentPage >= locals.pagination.totalPages ? 'disabled' : '' %> title="Next Page">
                        <i class="fa fa-chevron-right"></i>
                    </button>
                </div>
            </div>
        </div>
    </section>
</div>

<!-- jQuery (required for Select2) -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<!-- Select2 JS -->
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script>
$(document).ready(function() {
    $('.select2-dropdown').select2({
        placeholder: 'Select an option',
        allowClear: true,
        width: 'style',
        minimumResultsForSearch: 0
    });
});
</script>

<%- include('partials/footer', { jsFile: 'assignment-report' }) %>