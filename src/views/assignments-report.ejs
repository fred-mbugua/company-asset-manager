<%- include('partials/header', { pageTitle: 'Assignment Report', cssFile: 'assign-report' }) %>
<%- include('partials/navbar', { user: locals.user }) %>

<div class="main">
    <%- include('partials/sidebar') %>
    <section class="content-area">
        <div class="report-container">
            <h3>Asset Assignments Report</h3>

            <div class="filters">
                <select id="filter-tag">
                    <option value="">Asset Tags</option>
                    <% if (locals.assetTags && locals.assetTags.length) { %>
                        <% locals.assetTags.forEach(tag => { %>
                            <option value="<%= tag %>"><%= tag %></option>
                        <% }); %>
                    <% } %>
                </select>
                
                <select id="filter-department">
                    <option value="">All Department</option>
                    <% if (locals.departments && locals.departments.length) { %>
                        <% locals.departments.forEach(dept => { %>
                            <option value="<%= dept.name %>"><%= dept.name %></option>
                        <% }); %>
                    <% } %>
                </select>
                
                <select id="filter-employee">
                    <option value="">Employees</option>
                    <% if (locals.employees && locals.employees.length) { %>
                        <% locals.employees.forEach(employee => { %>
                            <option value="<%= employee %>"><%= employee %></option>
                        <% }); %>
                    <% } %>
                </select>
                
                <select id="filter-location">
                    <option value="">All Branches</option>
                    <% if (locals.locations && locals.locations.length) { %>
                        <% locals.locations.forEach(loc => { %>
                            <option value="<%= loc.name %>"><%= loc.name %></option>
                        <% }); %>
                    <% } %>
                </select>
                
                <input type="date" id="filter-from-date" placeholder="From Date">
                <input type="date" id="filter-to-date" placeholder="To Date">
    
                <button class="btn btn-view" id="search-btn">Search</button>
                <button class="btn btn-export" id="export-btn">Export to Excel</button>
            </div>

            <table class="report-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Asset Tag</th>
                        <th>Manufacturer</th>
                        <th>Model Name</th>
                        <th>Employee</th>
                        <th>Department</th>
                        <th>Assigned Date</th>
                        <th>Notes</th>
                        <th>Return Date</th>
                    </tr>
                </thead>
                <tbody id="assignments-table-body">
                    <% if (locals.initialAssignments && locals.initialAssignments.length > 0) { %>
                        <% locals.initialAssignments.forEach(assignment => { %>
                            <tr>
                                <td><%= assignment.id %></td>
                                <td><%= assignment.asset_tag %></td>
                                <td><%= assignment.manufacturer %></td>
                                <td><%= assignment.model %></td>
                                <td><%= assignment.employee_name %></td>
                                <td><%= assignment.department %></td>
                                <td><%= new Date(assignment.assignment_date).toLocaleDateString() %></td>
                                <td title="<%= assignment.notes || '' %>"><%= assignment.notes ? assignment.notes.substring(0, 50) + '...' : 'N/A' %></td>
                                <td><%= assignment.return_date ? new Date(assignment.return_date).toLocaleDateString() : 'N/A' %></td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr>
                            <td colspan="10" style="text-align:center;color:#888;">No assignments found.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>

            <div class="pagination-controls">
                <select id="page-size">
                    <option value="20" <%= locals.pagination.itemsPerPage === 20 ? 'selected' : '' %>>20 per page</option>
                    <option value="30" <%= locals.pagination.itemsPerPage === 30 ? 'selected' : '' %>>30 per page</option>
                    <option value="50" <%= locals.pagination.itemsPerPage === 50 ? 'selected' : '' %>>50 per page</option>
                </select>
                <button id="prev-btn" class="btn" <%= locals.pagination.currentPage === 1 ? 'disabled' : '' %>>Previous</button>
                <span id="page-info">Page <%= locals.pagination.currentPage %> of <%= locals.pagination.totalPages %> (<%= locals.totalAssignments %> total)</span>
                <button id="next-btn" class="btn" <%= locals.pagination.currentPage >= locals.pagination.totalPages ? 'disabled' : '' %>>Next</button>
            </div>
        </div>
    </section>
</div>

<%- include('partials/footer', { jsFile: 'assignment-report' }) %>