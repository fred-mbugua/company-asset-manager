<%- include('partials/header', { pageTitle: 'Expenses Report', cssFile: 'expenses-report' }) %>
<%- include('partials/navbar', { user: locals.user }) %>

<div class="main">
    <%- include('partials/sidebar') %>
    <section class="content-area">
        <div class="report-container">
            <h3>Asset Expenses Report</h3>

            <div class="filters">
                
                <select id="filter-tag">
                    <option value="">Asset Tags</option>
                    <% if (locals.assetTags && locals.assetTags.length) { %>
                        <% locals.assetTags.forEach(tag => { %>
                            <option value="<%= tag %>"><%= tag %></option>
                        <% }); %>
                    <% } %>
                </select>
                
                <select id="filter-type">
                    <option value="">All Expense Types</option>
                    <% if (locals.expenseTypes && locals.expenseTypes.length) { %>
                        <% locals.expenseTypes.forEach(type => { %>
                            <option value="<%= type.name %>"><%= type.name %></option>
                        <% }); %>
                    <% } %>
                </select>
                
                <select id="filter-department">
                    <option value="">All Department</option>
                    <% if (locals.departments && locals.departments.length) { %>
                        <% locals.departments.forEach(dept => { %>
                            <option value="<%= dept.name %>"><%= dept.name %></option>
                        <% }); %>
                    <% } %>
                </select>
                
                <select id="filter-location">
                    <option value="">Location</option>
                    <% if (locals.locations && locals.locations.length) { %>
                        <% locals.locations.forEach(loc => { %>
                            <option value="<%= loc.name %>"><%= loc.name %></option>
                        <% }); %>
                    <% } %>
                </select>
                
                <input type="date" id="filter-from-date" placeholder="From Date">
                <input type="date" id="filter-to-date" placeholder="To Date">

                <button class="btn btn-view" id="search-btn">Search</button>
                <button class="btn btn-export" id="export-btn">Export to Excel</button>
            </div>

            <div class="table-wrapper">
                <table class="report-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Asset Tag</th>
                            <th>Expense Type</th>
                            <th>Date</th>
                            <th>Amount</th>
                            <th>Vendor</th>
                            <th>Invoice No.</th>
                            <th>Department</th>
                            <th>Location</th>
                            <th>Notes</th>
                        </tr>
                    </thead>
                    <tbody id="expenses-table-body">
                        <% if (locals.initialExpenses && locals.initialExpenses.length > 0) { %>
                            <% locals.initialExpenses.forEach(expense => { %>
                                <tr>
                                    <td><%= expense.id %></td>
                                    <td><%= expense.asset_tag %></td>
                                    <td><%= expense.expense_type_name %></td>
                                    <td><%= new Date(expense.date).toLocaleDateString() %></td>
                                    <td><%= expense.amount %></td>
                                    <td><%= expense.vendor || 'N/A' %></td>
                                    <td><%= expense.invoice_number || 'N/A' %></td>
                                    <td><%= expense.department || 'N/A' %></td>
                                    <td><%= expense.location || 'N/A' %></td>
                                    <td title="<%= expense.notes || '' %>"><%= expense.notes ? expense.notes.substring(0, 50) + '...' : 'N/A' %></td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr>
                                <td colspan="10" style="text-align:center;color:#888;">No expenses found.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>

            <div class="pagination-controls">
                <select id="page-size">
                    <option value="20" <%= locals.pagination.itemsPerPage === 20 ? 'selected' : '' %>>20 per page</option>
                    <option value="30" <%= locals.pagination.itemsPerPage === 30 ? 'selected' : '' %>>30 per page</option>
                    <option value="50" <%= locals.pagination.itemsPerPage === 50 ? 'selected' : '' %>>50 per page</option>
                </select>
                <button id="prev-btn" class="btn" <%= locals.pagination.currentPage === 1 ? 'disabled' : '' %>>Previous</button>
                <span id="page-info">Page <%= locals.pagination.currentPage %> of <%= locals.pagination.totalPages %> (<%= locals.totalExpenses %> total)</span>
                <button id="next-btn" class="btn" <%= locals.pagination.currentPage >= locals.pagination.totalPages ? 'disabled' : '' %>>Next</button>
            </div>
        </div>
    </section>
</div>

<%- include('partials/footer', { jsFile: 'expenses-report' }) %> 