<%- include('partials/header', { pageTitle: 'Manage Departments', cssFile: 'manage-departments' }) %>
<%- include('partials/navbar', { user: locals.user }) %>

<div class="main">
    <%- include('partials/sidebar') %>
    <section class="content-area">
        <div class="department-management-container">
            <h3>Department Management</h3>
            
            <button id="add-dept-btn" class="btn btn-add">
                <i class="uil-plus"></i> Add New Department
            </button>

            <div id="dept-form-modal" class="modal">
                <div class="modal-content">
                    <div class="modal-header">
                        <h4><i class="uil-building"></i> <span id="modal-title">Add New Department</span></h4>
                        <span class="close-btn">&times;</span>
                    </div>
                    <div class="modal-body">
                        <form id="dept-form">
                            <input type="hidden" id="dept-id" name="id"> 

                            <div class="form-group">
                                <label for="name">Department Name <span class="required">*</span></label>
                                <input type="text" id="name" name="name" class="form-control" placeholder="Enter department name" required>
                            </div>
                            
                            <button type="submit" class="btn-submit"><i class="uil-check"></i> Save Department</button>
                        </form>
                    </div>
                </div>
            </div>
            
            <div class="dept-list-section mt-5">
                <h4>Existing Departments</h4>
                
                <div class="search-filter-section mb-3">
                    <input type="text" id="search-input" placeholder="Search by department name..." class="search-input">
                </div>

                <div class="responsive-table-wrapper">
                    <table id="departments-table" class="data-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Name</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="departments-table-body">
                            <% if (locals.departments && locals.departments.length > 0) { %>
                                <% locals.departments.forEach(dept => { %>
                                    <tr data-dept-id="<%= dept.id %>">
                                        <td data-label="ID"><%= dept.id %></td>
                                        <td data-label="Name"><%= dept.name %></td>
                                        <td data-label="Actions" class="actions-cell">
                                            <button class="btn btn-sm btn-edit" data-id="<%= dept.id %>">Edit</button>
                                            <button class="btn btn-sm btn-delete" data-id="<%= dept.id %>">Delete</button>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="3" style="text-align:center;">No departments found.</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
                
                <div class="pagination-controls">
                    <div class="pagination-info">
                        <select id="page-size">
                            <option value="10" selected>10 per page</option>
                            <option value="20">20 per page</option>
                            <option value="50">50 per page</option>
                        </select>
                        <span id="page-info">Page 1 of 1 (0 total)</span>
                    </div>
                    <div class="pagination-buttons">
                        <button id="prev-btn" class="btn btn-page" disabled title="Previous Page">
                            <i class="fa fa-chevron-left"></i>
                        </button>
                        <button id="next-btn" class="btn btn-page" disabled title="Next Page">
                            <i class="fa fa-chevron-right"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

<%- include('partials/footer', { jsFile: 'manage-departments' }) %>