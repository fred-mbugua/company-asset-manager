<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>View Assets</title>
  <link rel="stylesheet" href="assets/css/viewassets.css">
  <style></style>
</head>
<body>
  <div class="assets-container" id="assets-list-section">
    <h3>All Assets</h3>
    <!-- Filters -->
    <div class="filters">
      <input type="text" id="filter-tag" placeholder="Asset Tag">
      <input type="text" id="filter-serial" placeholder="Serial Number">
      <select id="filter-type">
        <option value="">All Types</option>
        <option value="Laptop">Laptop</option>
        <option value="Printer">Printer</option>
        <option value="Router">Router</option>
        <option value="Switch">Switch</option>
        <option value="CCTV">CCTV</option>
        <option value="Other">Other</option>
      </select>
      <input type="text" id="filter-location" placeholder="Location">
      <button class="btn btn-view" id="search-btn">Search</button>
    </div>
    <!-- Asset Table -->
    <table>
      <thead>
        <tr>
          <th>ID</th><th>Asset Tag</th><th>Type</th><th>Manufacturer</th>
          <th>Model</th><th>Serial</th><th>Status</th><th>Location</th>
          <th>Purchase Date</th><th>Actions</th>
        </tr>
      </thead>
      <tbody id="asset-table-body">
        <tr><td colspan="10" style="text-align:center;color:#888;">Loading...</td></tr>
      </tbody>
    </table>
  </div>

  <!-- View/Edit Section -->
  <div class="assets-container" id="asset-detail-section" style="display:none;">
    <h3 id="asset-form-title">Asset Details</h3>
    <form id="asset-detail-form" class="asset-form"></form>
    <div class="form-actions" id="asset-form-actions"></div>
  </div>

  <script></script>
  <script src="assets/js/api.js"></script>
  <script src="assets/js/viewassets.js"></script>
</body>
</html>
