<%- include('partials/header', { pageTitle: 'View Assets', cssFile: 'viewassets' }) %>
<!-- Select2 CSS -->
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<%- include('partials/navbar') %>

<div class="main">
    <%- include('partials/sidebar') %>
    <section class="content-area">
        <div class="assets-container" id="assets-list-section">
            <h3>All Assets</h3>
            
            <div class="filters">
                <div class="filter-field">
                    <label for="filter-tag">Asset Tag</label>
                    <input type="text" id="filter-tag" placeholder="Enter asset tag">
                </div>
                <div class="filter-field">
                    <label for="filter-serial">Serial Number</label>
                    <input type="text" id="filter-serial" placeholder="Enter serial number">
                </div>
                <div class="filter-field">
                    <label for="filter-type">Asset Type</label>
                    <select id="filter-type" class="select2-dropdown" style="width: 100%;">
                        <option value="">All Types</option>
                        <% if (locals.assetTypes && locals.assetTypes.length > 0) { %>
                            <% locals.assetTypes.forEach(type => { %>
                                <option value="<%= type.name %>"><%= type.name %></option>
                            <% }); %>
                        <% } %>
                    </select>
                </div>
                <div class="filter-field">
                    <label for="filter-status">Status</label>
                    <select id="filter-status" class="select2-dropdown" style="width: 100%;">
                        <option value="">All Statuses</option>
                        <% if (locals.assetStatuses && locals.assetStatuses.length > 0) { %>
                            <% locals.assetStatuses.forEach(status => { %>
                                <option value="<%= status.name %>"><%= status.name %></option>
                            <% }); %>
                        <% } %>
                    </select>
                </div>
                <div class="filter-field">
                    <label for="filter-location">Location</label>
                    <select id="filter-location" class="select2-dropdown" style="width: 100%;">
                        <option value="">All Locations</option>
                        <% if (locals.branches && locals.branches.length > 0) { %>
                            <% locals.branches.forEach(branch => { %>
                                <option value="<%= branch.name %>"><%= branch.name %></option>
                            <% }); %>
                        <% } %>
                    </select>
                </div>
                <div class="date-filters">
                    <label>Purchase Date Range:</label>
                    <input type="date" id="filter-from-date" placeholder="From Date">
                    <input type="date" id="filter-to-date" placeholder="To Date">
                </div>
                <button class="btn btn-view" id="search-btn">Search</button>
            </div>
            <div class="table-wrapper">
                <table>
                    <thead>
                        <tr>
                            <th>ID</th><th>Asset Tag</th><th>Type</th><th>Manufacturer</th>
                            <th>Model</th><th>Serial</th><th>Status</th><th>Location</th>
                            <th>Purchase Date</th><th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="asset-table-body">
                        <% 
                        const userRole = locals.user?.role || '';
                        const isAdmin = userRole === 'Admin' || userRole === 'Super Admin';
                        %>
                        <% if (locals.assets && locals.assets.length > 0) { %>
                            <% locals.assets.forEach(asset => { %>
                                <tr data-id="<%= asset.id %>">
                                    <td><%= asset.id %></td>
                                    <td><%= asset.asset_tag %></td>
                                    <td><%= asset.asset_type %></td>
                                    <td><%= asset.manufacturer %></td>
                                    <td><%= asset.model %></td>
                                    <td><%= asset.serial_number %></td>
                                    <td><%= asset.status %></td>
                                    <td><%= asset.location %></td>
                                    <td><span data-date="<%= asset.purchase_date %>"></span></td>
                                    <td>
                                        <button class="btn btn-edit" onclick="showAssetDetails(<%= asset.id %>)">View/Edit</button>
                                        <button class="btn btn-view" onclick="showAssignmentHistory(<%= asset.id %>, '<%= asset.asset_tag %>')">History</button>
                                        <% if (isAdmin) { %>
                                        <button class="btn btn-delete" onclick="confirmDelete(<%= asset.id %>, '<%= asset.asset_tag %>')">Delete</button>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                             <tr><td colspan="10" style="text-align:center;color:#888;">No assets found.</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
            
            <div class="pagination-controls">
                <select id="page-size">
                    <option value="20" selected>20 per page</option>
                    <option value="30">30 per page</option>
                    <option value="50">50 per page</option>
                </select>
                <button id="prev-btn" class="btn" <%= pagination.hasPrevPage ? '' : 'disabled' %>>Previous</button>
                <span id="page-info">Page <%= pagination.currentPage %> of <%= pagination.totalPages %> (<%= totalAssets %> total)</span>
                <button id="next-btn" class="btn" <%= pagination.hasNextPage ? '' : 'disabled' %>>Next</button>
            </div>
        </div>

        <div class="assets-container" id="asset-detail-section" style="display:none;">
            <h3 id="asset-form-title">Asset Details</h3>
            <form id="asset-detail-form" class="asset-form">
                </form>
            <div class="form-actions" id="asset-form-actions">
                <button class="btn btn-save" id="save-asset-btn">Save Changes</button>
                <button class="btn btn-cancel" onclick="document.getElementById('asset-detail-section').style.display='none'; document.getElementById('assets-list-section').style.display='block';">Cancel</button>
            </div>
        </div>
    </section>
</div>

<!-- Delete Confirmation Modal -->
<div id="deleteModal" class="modal">
    <div class="modal-content">
        <h3>Confirm Delete</h3>
        <p id="delete-message">Are you sure you want to delete this asset?</p>
        <div class="modal-actions">
            <button class="btn btn-danger" id="confirm-delete-btn">Delete</button>
            <button class="btn btn-cancel" id="cancel-delete-btn">Cancel</button>
        </div>
    </div>
</div>

<!-- Assignment History Modal -->
<div id="historyModal" class="modal">
    <div class="modal-content history-modal">
        <div class="modal-header">
            <h3>Assignment History</h3>
            <span class="close" onclick="closeHistoryModal()">&times;</span>
        </div>
        <div class="modal-body">
            <p id="history-asset-info" style="margin-bottom: 20px; font-weight: 600; color: #333;"></p>
            <div id="history-content">
                <p style="text-align: center; color: #888;">Loading history...</p>
            </div>
        </div>
    </div>
</div>

<!-- Select2 JS -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script>
window.isUserAdmin = <%= (locals.user?.role === 'Admin' || locals.user?.role === 'Super Admin') ? 'true' : 'false' %>;
</script>
<%- include('partials/footer', { jsFile: 'viewassets' }) %>