<%- include('partials/header', { pageTitle: 'Access Denied', cssFile: '404' }) %>

<div class="error-container">
    <div class="error-content">
        <div class="error-icon">
            <i class="uil uil-lock-alt"></i>
        </div>
        <h1>403</h1>
        <h2>Access Denied</h2>
        <p><%= locals.message || 'You do not have permission to access this resource.' %></p>
        <div class="error-actions">
            <a href="/dashboard" class="btn btn-primary">
                <i class="uil uil-home"></i> Go to Dashboard
            </a>
            <a href="javascript:history.back()" class="btn btn-secondary">
                <i class="uil uil-arrow-left"></i> Go Back
            </a>
        </div>
    </div>
</div>

<style>
.error-container {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    background: #f5f5f5;
    padding: 20px;
}

.error-content {
    text-align: center;
    background: white;
    padding: 60px 40px;
    border-radius: 20px;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    max-width: 500px;
}

.error-icon {
    font-size: 80px;
    color: #ef4444;
    margin-bottom: 20px;
}

.error-content h1 {
    font-size: 120px;
    font-weight: 700;
    color: #ef4444;
    margin: 0;
    line-height: 1;
}

.error-content h2 {
    font-size: 28px;
    color: #333;
    margin: 10px 0 20px;
}

.error-content p {
    color: #666;
    font-size: 16px;
    margin-bottom: 30px;
    line-height: 1.6;
}

.error-actions {
    display: flex;
    gap: 15px;
    justify-content: center;
    flex-wrap: wrap;
}

.error-actions .btn {
    padding: 12px 24px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: all 0.3s ease;
}

.error-actions .btn-primary {
    background: #f97316;
    color: white;
}

.error-actions .btn-primary:hover {
    background: #ea580c;
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(249, 115, 22, 0.3);
}

.error-actions .btn-secondary {
    background: #f1f1f1;
    color: #333;
    border: 2px solid #22c55e;
}

.error-actions .btn-secondary:hover {
    background: #22c55e;
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(34, 197, 94, 0.3);
}
</style>

<%- include('partials/footer', { jsFile: null }) %>
