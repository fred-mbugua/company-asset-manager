<%
    const userName = locals.user?.email || 'Admin';
    const appName = locals.systemConfig?.app_name || 'Asset Management System';
    const companyLogo = locals.systemConfig?.company_logo_url || null;
%>
<div class="navbar">
    <span class="menu-toggle"><i class="fa fa-bars"></i></span>
    <div class="app-branding">
        <% if (companyLogo) { %>
            <img src="<%= companyLogo %>" alt="<%= appName %>" class="app-logo">
        <% } %>
        <h1><%= appName %></h1>
    </div>
    <div class="admin-info-dropdown">
        <div class="admin-info-toggle">
            <i class="fa fa-user-circle"></i>
            <span class="user-name"><%= userName %></span>
            <i class="fa fa-chevron-down dropdown-arrow"></i>
        </div>
        <div class="admin-dropdown-menu">
            <div class="dropdown-item user-email">
                <i class="fa fa-envelope"></i> <%= userName %>
            </div>
            <a href="#" id="logout-link" class="dropdown-item">
                <i class="fa fa-sign-out"></i> Logout
            </a>
        </div>
    </div>
</div>