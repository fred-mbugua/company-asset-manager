<!-- Attachments Section Partial -->
<!-- Usage: include this partial where you want to show attachments -->
<!-- Pass entityType ('asset' or 'expense') and entityId as parameters -->
<%
    const entityType = locals.entityType || 'asset'; // 'asset' or 'expense'
    const entityId = locals.entityId || null;
    const attachmentEndpoint = entityType === 'asset' ? 'asset-attachments' : 'expense-attachments';
%>

<div class="attachments-section" data-entity-type="<%= entityType %>" data-entity-id="<%= entityId %>">
    <h4><i class="uil uil-paperclip"></i> Attachments & Notes</h4>
    
    <!-- Upload Form -->
    <div class="attachment-upload-form">
        <div class="upload-area">
            <input type="file" id="<%= entityType %>-attachment-file-<%= entityId %>" class="attachment-file-input" accept="*/*" style="display: none;">
            <label for="<%= entityType %>-attachment-file-<%= entityId %>" class="upload-label">
                <i class="uil uil-upload"></i>
                <span>Choose File or Drag & Drop</span>
                <small>Maximum file size: 10MB</small>
            </label>
            <div class="selected-file" style="display: none;">
                <i class="uil uil-file"></i>
                <span class="file-name"></span>
                <button type="button" class="clear-file-btn">&times;</button>
            </div>
        </div>
        <div class="upload-notes">
            <label for="<%= entityType %>-attachment-notes-<%= entityId %>">Notes (Optional)</label>
            <textarea id="<%= entityType %>-attachment-notes-<%= entityId %>" class="attachment-notes-input" rows="2" placeholder="Add any notes about this attachment..."></textarea>
        </div>
        <button type="button" class="btn btn-upload-attachment" data-entity-type="<%= entityType %>" data-entity-id="<%= entityId %>">
            <i class="uil uil-upload-alt"></i> Upload Attachment
        </button>
    </div>

    <!-- Attachments List -->
    <div class="attachments-list" id="<%= entityType %>-attachments-list-<%= entityId %>">
        <p class="loading-text">Loading attachments...</p>
    </div>
</div>

<style>
.attachments-section {
    margin-top: 2rem;
    padding: 1.5rem;
    background: #f8f9fa;
    border-radius: 8px;
    border: 1px solid #e0e0e0;
}

.attachments-section h4 {
    margin-top: 0;
    margin-bottom: 1.5rem;
    color: #2c3e50;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.attachment-upload-form {
    background: white;
    padding: 1.5rem;
    border-radius: 6px;
    margin-bottom: 1.5rem;
}

.upload-area {
    margin-bottom: 1rem;
}

.upload-label {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 2rem;
    border: 2px dashed #ddd;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.3s ease;
    background: #fafafa;
}

.upload-label:hover {
    border-color: #1abc9c;
    background: #f0f9f7;
}

.upload-label i {
    font-size: 2.5rem;
    color: #1abc9c;
}

.upload-label small {
    color: #7f8c8d;
    font-size: 0.875rem;
}

.selected-file {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem;
    background: #e8f8f5;
    border: 1px solid #1abc9c;
    border-radius: 6px;
}

.selected-file i {
    font-size: 1.5rem;
    color: #1abc9c;
}

.clear-file-btn {
    margin-left: auto;
    background: none;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: #7f8c8d;
}

.clear-file-btn:hover {
    color: #e74c3c;
}

.upload-notes label {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: 500;
    color: #2c3e50;
}

.attachment-notes-input {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid #ddd;
    border-radius: 4px;
    font-family: inherit;
    resize: vertical;
}

.btn-upload-attachment {
    background: #1abc9c;
    color: white;
    padding: 0.75rem 1.5rem;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 500;
    transition: background 0.3s ease;
}

.btn-upload-attachment:hover {
    background: #16a085;
}

.btn-upload-attachment:disabled {
    background: #95a5a6;
    cursor: not-allowed;
}

.attachments-list {
    max-height: 400px;
    overflow-y: auto;
}

.attachment-item {
    background: white;
    padding: 1rem;
    border-radius: 6px;
    margin-bottom: 0.75rem;
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    border: 1px solid #e0e0e0;
    transition: box-shadow 0.3s ease;
}

.attachment-item:hover {
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}

.attachment-icon {
    font-size: 2rem;
    color: #3498db;
    flex-shrink: 0;
}

.attachment-info {
    flex: 1;
}

.attachment-name {
    font-weight: 600;
    color: #2c3e50;
    margin-bottom: 0.25rem;
    word-break: break-word;
}

.attachment-meta {
    font-size: 0.875rem;
    color: #7f8c8d;
    margin-bottom: 0.5rem;
}

.attachment-notes {
    font-size: 0.875rem;
    color: #555;
    margin-top: 0.5rem;
    padding: 0.5rem;
    background: #f8f9fa;
    border-left: 3px solid #3498db;
    border-radius: 3px;
}

.attachment-actions {
    display: flex;
    gap: 0.5rem;
    flex-shrink: 0;
}

.btn-small {
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.3s ease;
}

.btn-download {
    background: #3498db;
    color: white;
}

.btn-download:hover {
    background: #2980b9;
}

.btn-delete-attachment {
    background: #e74c3c;
    color: white;
}

.btn-delete-attachment:hover {
    background: #c0392b;
}

.no-attachments {
    text-align: center;
    color: #888;
    padding: 2rem;
}

.loading-text {
    text-align: center;
    color: #888;
    padding: 1rem;
}
</style>

<script>
// This script will be initialized by the parent page's JavaScript
// It requires the loadAttachments and uploadAttachment functions to be defined
</script>
