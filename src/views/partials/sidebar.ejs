<%
    // Assuming 'user' object is passed to EJS and contains user role information (e.g., user.role_id or user.role)
    const userRole = locals.user?.role || 'Standard User'; 
    
    // Get current path to determine active menu item
    const currentPath = locals.currentPath || '';
    
    // Access rules for navigation items
    const menuItems = [
        { title: 'Dashboard', icon: 'uil-dashboard', url: '/dashboard', roles: ['Admin', 'Standard User'] },
        { 
            title: 'Assets', icon: 'uil-briefcase', roles: ['Admin', 'Standard User'], id: 'assets-menu', submenu: [
                { title: 'Create', url: '/assets/create', roles: ['Admin', 'Standard User'] },
                { title: 'View', url: '/assets/view', roles: ['Admin', 'Standard User'], parent: 'assets-menu' },
            ]
        },
        { 
            title: 'Assignments', icon: 'uil-clipboard-notes', roles: ['Admin', 'Standard User'], id: 'assignments-menu', submenu: [
                { title: 'View', url: '/assets/view', roles: ['Admin', 'Standard User'], parent: 'assignments-menu' },
                { title: 'Assign', url: '/assets/assign', roles: ['Admin'] }, // Only Admin can assign
            ]
        },
        { 
            title: 'Expenses', icon: 'uil-receipt', roles: ['Admin', 'Standard User'], id: 'expenses-menu', submenu: [
                { title: 'Create', url: '/expenses/create', roles: ['Admin', 'Standard User'] },
            ]
        },
        { title: 'Reports', icon: 'uil-analytics', url: '/reports', roles: ['Admin'], id: 'reports-menu', submenu: [ // Restricted to Admin
                { title: 'Assets', url: '/reports/assets', roles: ['Admin', 'Standard User'] },
                { title: 'Expenses', url: '/reports/expenses', roles: ['Admin', 'Standard User'] },
                { title: 'Assignments', url: '/reports/assignments', roles: ['Admin', 'Standard User'] },
                { title: 'Action Logs', url: '/reports/action-logs', roles: ['Admin'] }, // Only Admin can access Action Logs
            ] 
        },
        { 
            title: 'Administration', icon: 'uil-cog', roles: ['Admin'], id: 'admin-menu', submenu: [ // Restricted to Admin
                { title: 'Users', url: '/users/manage', roles: ['Admin'] },
                { title: 'Branches', url: '/branches/manage', roles: ['Admin'] },
                { title: 'Departments', url: '/departments/manage', roles: ['Admin'] },
            ]
        },
    ];

    const hasAccess = (requiredRoles) => requiredRoles.includes(userRole);
%>

<aside class="sidebar" id="sidebar">
    <ul id="menu">
        <% menuItems.forEach((item, itemIndex) => { %>
            <% if (hasAccess(item.roles)) { %>
                <% if (item.submenu) { %>
                    <% 
                        // Check if any submenu item matches current path
                        const hasMatchingUrl = item.submenu.some(subItem => 
                            subItem.url === currentPath && hasAccess(subItem.roles)
                        );
                    %>
                    <li class="has-sub" data-menu-id="<%= item.id || '' %>" data-has-match="<%= hasMatchingUrl %>">
                        <i class="<%= item.icon %>"></i><span><%= item.title %></span>
                        <ul class="submenu">
                            <% item.submenu.forEach(subItem => { %>
                                <% if (hasAccess(subItem.roles)) { %>
                                    <% const menuParam = subItem.parent || item.id || ''; %>
                                    <li data-parent-menu="<%= menuParam %>">
                                        <a href="<%= subItem.url %>?from=<%= menuParam %>"><%= subItem.title %></a>
                                    </li>
                                <% } %>
                            <% }) %>
                        </ul>
                    </li>
                <% } else { %>
                    <% const isActive = item.url === currentPath; %>
                    <li data-content="<%= item.title.toLowerCase().replace(/\s/g, '-') %>" class="<%= isActive ? 'active' : '' %>">
                        <a href="<%= item.url %>">
                            <i class="<%= item.icon %>"></i><span><%= item.title %></span>
                        </a>
                    </li>
                <% } %>
            <% } %>
        <% }) %>
    </ul>
</aside>