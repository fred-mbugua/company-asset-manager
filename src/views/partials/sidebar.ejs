<%
    // Assuming 'user' object is passed to EJS and contains user role information (e.g., user.role_id or user.role_name)
    const userRole = locals.user?.role_name || locals.user?.role || 'Standard User';
    const userPermissions = locals.userPermissions || null; // Will be populated by middleware if permissions system is used
    
    // Get current path to determine active menu item
    const currentPath = locals.currentPath || '';
    
    // Get logo and app name
    const appName = locals.systemConfig?.app_name || 'Asset Management System';
    const companyLogo = locals.systemConfig?.company_logo_url || null;
    
    // Check if user is admin
    const isAdmin = userRole === 'Admin';
    
    // Access rules for navigation items
    // Using '*' to indicate all authenticated users have access
    // module_code is used for permission checking when userPermissions is available
    const menuItems = [
        { title: 'Dashboard', icon: 'uil-dashboard', url: '/dashboard', roles: ['*'], module_code: 'DASHBOARD' },
        { 
            title: 'Assets', icon: 'uil-briefcase', roles: ['*'], id: 'assets-menu', module_code: 'ASSETS', submenu: [
                { title: 'Create', url: '/assets/create', roles: ['*'], module_code: 'ASSETS_CREATE' },
                { title: 'View', url: '/assets/view', roles: ['*'], parent: 'assets-menu', module_code: 'ASSETS_VIEW' },
            ]
        },
        { 
            title: 'Assignments', icon: 'uil-clipboard-notes', roles: ['*'], id: 'assignments-menu', module_code: 'ASSIGNMENTS', submenu: [
                { title: 'View', url: '/assets/view', roles: ['*'], parent: 'assignments-menu', module_code: 'ASSIGNMENTS_VIEW' },
                { title: 'Assign', url: '/assets/assign', roles: ['Admin'], module_code: 'ASSIGNMENTS_ASSIGN' },
            ]
        },
        { 
            title: 'Expenses', icon: 'uil-receipt', roles: ['*'], id: 'expenses-menu', module_code: 'EXPENSES', submenu: [
                { title: 'Create', url: '/expenses/create', roles: ['*'], module_code: 'EXPENSES_CREATE' },
            ]
        },
        { 
            title: 'Repair Requests', icon: 'uil-wrench', roles: ['*'], id: 'repair-requests-menu', module_code: 'REPAIR_REQUESTS', submenu: [
                { title: 'All Requests', url: '/repair-requests', roles: ['*'], module_code: 'REPAIR_REQUESTS_LIST' },
                { title: 'New Request', url: '/repair-requests/new', roles: ['*'], module_code: 'REPAIR_REQUESTS_NEW' },
                { title: 'Workflow Config', url: '/repair-requests/workflow', roles: ['Admin'], module_code: 'REPAIR_REQUESTS_WORKFLOW' },
            ]
        },
        { title: 'Reports', icon: 'uil-analytics', url: '/reports', roles: ['*'], id: 'reports-menu', module_code: 'REPORTS', submenu: [
                { title: 'Assets', url: '/reports/assets', roles: ['*'], module_code: 'REPORTS_ASSETS' },
                { title: 'Expenses', url: '/reports/expenses', roles: ['*'], module_code: 'REPORTS_EXPENSES' },
                { title: 'Assignments', url: '/reports/assignments', roles: ['*'], module_code: 'REPORTS_ASSIGNMENTS' },
                { title: 'Repair Summary', url: '/reports/repair-summary', roles: ['*'], module_code: 'REPORTS_REPAIR_SUMMARY' },
                { title: 'Action Logs', url: '/reports/action-logs', roles: ['Admin'], module_code: 'REPORTS_ACTION_LOGS' },
            ] 
        },
        { 
            title: 'Administration', icon: 'uil-cog', roles: ['Admin'], id: 'admin-menu', module_code: 'ADMINISTRATION', submenu: [
                { title: 'Users', url: '/users/manage', roles: ['Admin'], module_code: 'ADMIN_USERS' },
                { title: 'Roles', url: '/roles/manage', roles: ['Admin'], module_code: 'ADMIN_ROLES' },
                { title: 'Permissions', url: '/permissions/manage', roles: ['Admin'], module_code: 'ADMIN_PERMISSIONS' },
                { title: 'Branches', url: '/branches/manage', roles: ['Admin'], module_code: 'ADMIN_BRANCHES' },
                { title: 'Branch Hierarchy', url: '/branches/hierarchy', roles: ['Admin'], module_code: 'ADMIN_BRANCHES' },
                { title: 'Departments', url: '/departments/manage', roles: ['Admin'], module_code: 'ADMIN_DEPARTMENTS' },
                { title: 'Asset Statuses', url: '/asset-statuses/manage', roles: ['Admin'], module_code: 'ADMIN_ASSET_STATUSES' },
                { title: 'Asset Types', url: '/asset-types/manage', roles: ['Admin'], module_code: 'ADMIN_ASSET_TYPES' },
                { title: 'Expense Types', url: '/expense-types/manage', roles: ['Admin'], module_code: 'ADMIN_EXPENSE_TYPES' },
                { title: 'Repair Types', url: '/repair-request-types/manage', roles: ['Admin'], module_code: 'ADMIN_REPAIR_TYPES' },
                { title: 'Repair Statuses', url: '/repair-request-statuses/manage', roles: ['Admin'], module_code: 'ADMIN_REPAIR_STATUSES' },
                { title: 'Repair Priorities', url: '/repair-request-priorities/manage', roles: ['Admin'], module_code: 'ADMIN_REPAIR_PRIORITIES' },
            ]
        },
        { 
            title: 'Settings', icon: 'uil-setting', roles: ['Admin'], id: 'settings-menu', module_code: 'SETTINGS', submenu: [
                { title: 'System Configuration', url: '/settings/configuration', roles: ['Admin'], module_code: 'SETTINGS_SYSTEM' },
            ]
        },
    ];

    /**
     * Check access using dynamic permissions if available, otherwise fall back to role-based
     * @param {object} item - Menu item with roles array and optional module_code
     * @returns {boolean} - Whether user has access
     */
    const hasAccess = (item) => {
        // Admin always has access
        if (isAdmin) return true;
        
        // If dynamic permissions are available and item has module_code, check permissions
        if (userPermissions && item.module_code) {
            const modulePerms = userPermissions[item.module_code];
            
            if (modulePerms && modulePerms.actions) {
                // Check if user has at least read permission for this module
                const actions = modulePerms.actions;
                if (Array.isArray(actions)) {
                    return actions.includes('read');
                }
            }
            // If module_code is specified but not in permissions, deny access
            // This ensures items with explicit module_code require that permission
            return false;
        }
        
        // If no permissions system or no module_code, fallback to role-based access
        // But only allow if roles include '*' (all users) or specific user role
        return item.roles.includes('*') || item.roles.includes(userRole);
    };
    
    /**
     * Check if a parent menu should be visible based on whether any of its submenus are accessible
     * @param {object} item - Menu item with submenu array
     * @returns {boolean} - Whether the parent menu should be shown
     */
    const hasAccessibleSubmenu = (item) => {
        if (!item.submenu || item.submenu.length === 0) return false;
        return item.submenu.some(subItem => hasAccess(subItem));
    };
%>

<aside class="sidebar" id="sidebar">
    <div class="sidebar-logo">
        <% if (companyLogo) { %>
            <img src="<%= companyLogo %>" alt="<%= appName %>" class="sidebar-logo-img">
        <% } else { %>
            <div class="sidebar-logo-placeholder">
                <i class="uil uil-building"></i>
            </div>
        <% } %>
    </div>
    <ul id="menu">
        <% menuItems.forEach((item, itemIndex) => { %>
            <% 
                // For items with submenu, check if at least one submenu item is accessible
                // For parent menus, we should show them if ANY child is accessible
                // For single items (no submenu), check the item's direct access
                const itemHasAccess = item.submenu 
                    ? hasAccessibleSubmenu(item)  // Parent menu: show if any child is accessible
                    : hasAccess(item);            // Single item: check its own permission
            %>
            <% if (itemHasAccess) { %>
                <% if (item.submenu) { %>
                    <% 
                        // Check if any submenu item matches current path
                        const hasMatchingUrl = item.submenu.some(subItem => 
                            subItem.url === currentPath && hasAccess(subItem)
                        );
                    %>
                    <li class="has-sub" data-menu-id="<%= item.id || '' %>" data-has-match="<%= hasMatchingUrl %>">
                        <i class="<%= item.icon %>"></i><span><%= item.title %></span>
                        <ul class="submenu">
                            <% item.submenu.forEach(subItem => { %>
                                <% if (hasAccess(subItem)) { %>
                                    <% const menuParam = subItem.parent || item.id || ''; %>
                                    <li data-parent-menu="<%= menuParam %>">
                                        <a href="<%= subItem.url %>?from=<%= menuParam %>"><%= subItem.title %></a>
                                    </li>
                                <% } %>
                            <% }) %>
                        </ul>
                    </li>
                <% } else { %>
                    <% const isActive = item.url === currentPath; %>
                    <li data-content="<%= item.title.toLowerCase().replace(/\s/g, '-') %>" class="<%= isActive ? 'active' : '' %>">
                        <a href="<%= item.url %>">
                            <i class="<%= item.icon %>"></i><span><%= item.title %></span>
                        </a>
                    </li>
                <% } %>
            <% } %>
        <% }) %>
    </ul>
</aside>