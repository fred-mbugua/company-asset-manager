<%- include('partials/header', { pageTitle: 'Login', cssFile: 'login' }) %>
<%
    const appName = locals.systemConfig?.app_name || 'Asset Management System';
    const companyLogo = locals.systemConfig?.company_logo_url || null;
%>

  <div class="login-container">
    <div class="app-name">
      <% if (companyLogo) { %>
        <img src="<%= companyLogo %>" alt="<%= appName %>" class="login-logo">
      <% } %>
      <h1><%= appName %></h1>
      <p class="app-subtitle">JSL-ICT</p>
    </div>
    <h2>Login</h2>
    <div id="login-form">
      <input type="email" id="email" placeholder="Email" required>
      <input type="password" id="password" placeholder="Password" required>
      <button id="login-button">Login</button>
    </div>
    <p id="error" style="color: red; margin-top: 10px; display: none;"></p>
  </div>

<%- include('partials/footer', { jsFile: 'login' }) %>