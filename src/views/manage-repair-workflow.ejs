<%- include('partials/header', { pageTitle: 'Repair Workflow Configuration', cssFile: 'manage-repair-workflow' }) %>
<!-- Select2 CSS -->
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<%- include('partials/navbar', { user: locals.user }) %>

<div class="main">
    <%- include('partials/sidebar') %>
    <section class="content-area">
        <div class="management-container">
            <div class="page-header">
                <div class="header-left">
                    <h3><i class="uil uil-process"></i> Repair Workflow Configuration</h3>
                    <p class="subtitle">Configure approval stages and role permissions for repair requests</p>
                </div>
            </div>

            <!-- Tabs -->
            <div class="config-tabs">
                <button class="tab-btn active" data-tab="stages">
                    <i class="uil uil-list-ui-alt"></i> Workflow Stages
                </button>
                <button class="tab-btn" data-tab="permissions">
                    <i class="uil uil-shield-check"></i> Role Permissions
                </button>
            </div>

            <!-- Workflow Stages Tab -->
            <div id="stages-tab" class="tab-content active">
                <div class="section-header">
                    <h4>Workflow Stages</h4>
                    <p class="text-muted">Define the stages in the repair request approval workflow</p>
                </div>

                <div class="table-responsive">
                    <table class="data-table" id="stages-table">
                        <thead>
                            <tr>
                                <th>Order</th>
                                <th>Stage Key</th>
                                <th>Stage Name</th>
                                <th>From Status</th>
                                <th>To Status</th>
                                <th>Action Type</th>
                                <th>Requirements</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="stages-table-body">
                            <tr>
                                <td colspan="9" class="loading-row">
                                    <i class="uil uil-spinner-alt spin"></i> Loading stages...
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Permissions Tab -->
            <div id="permissions-tab" class="tab-content">
                <div class="section-header">
                    <h4>Role Permissions</h4>
                    <p class="text-muted">Configure which roles can perform each workflow action</p>
                </div>

                <div class="permissions-grid" id="permissions-grid">
                    <!-- Permissions will be loaded dynamically -->
                </div>
            </div>
        </div>
    </section>
</div>

<!-- Edit Stage Modal -->
<div id="stage-modal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h3 id="modal-title"><i class="uil uil-edit"></i> Edit Workflow Stage</h3>
            <button type="button" class="close-btn">&times;</button>
        </div>
        <form id="stage-form">
            <input type="hidden" id="stage-id">
            <div class="modal-body">
                <div class="form-row">
                    <div class="form-group">
                        <label for="stage-key">Stage Key <span class="required">*</span></label>
                        <input type="text" id="stage-key" name="stage_key" required placeholder="e.g., ict-approve" readonly>
                        <small class="text-muted">Unique identifier (read-only)</small>
                    </div>
                    <div class="form-group">
                        <label for="stage-name">Stage Name <span class="required">*</span></label>
                        <input type="text" id="stage-name" name="stage_name" required placeholder="e.g., ICT Approval">
                    </div>
                </div>

                <div class="form-group">
                    <label for="stage-description">Description</label>
                    <textarea id="stage-description" name="description" rows="2" placeholder="Brief description of this stage..."></textarea>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="from-status">From Status</label>
                        <select id="from-status" name="from_status_id" class="select2-dropdown" style="width: 100%;">
                            <option value="">Any Status</option>
                            <% if (locals.statuses) { %>
                                <% locals.statuses.forEach(status => { %>
                                    <option value="<%= status.id %>"><%= status.name %></option>
                                <% }); %>
                            <% } %>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="to-status">To Status <span class="required">*</span></label>
                        <select id="to-status" name="to_status_id" class="select2-dropdown" style="width: 100%;" required>
                            <option value="">Select Status</option>
                            <% if (locals.statuses) { %>
                                <% locals.statuses.forEach(status => { %>
                                    <option value="<%= status.id %>"><%= status.name %></option>
                                <% }); %>
                            <% } %>
                        </select>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="action-type">Action Type <span class="required">*</span></label>
                        <select id="action-type" name="action_type" class="select2-dropdown" style="width: 100%;" required>
                            <option value="approve">Approve</option>
                            <option value="reject">Reject</option>
                            <option value="transition">Transition</option>
                            <option value="complete">Complete</option>
                            <option value="cancel">Cancel</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="display-order">Display Order</label>
                        <input type="number" id="display-order" name="display_order" min="0" value="0">
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="stage-icon">Icon</label>
                        <input type="text" id="stage-icon" name="icon" placeholder="uil-check">
                    </div>
                    <div class="form-group">
                        <label for="button-color">Button Color</label>
                        <select id="button-color" name="button_color" class="select2-dropdown" style="width: 100%;">
                            <option value="success">Green (Success)</option>
                            <option value="danger">Red (Danger)</option>
                            <option value="warning">Yellow (Warning)</option>
                            <option value="primary">Blue (Primary)</option>
                            <option value="secondary">Gray (Secondary)</option>
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label>Requirements</label>
                    <div class="checkbox-group">
                        <label class="checkbox-label">
                            <input type="checkbox" id="requires-notes" name="requires_notes">
                            <span>Requires Notes</span>
                        </label>
                        <label class="checkbox-label">
                            <input type="checkbox" id="requires-invoice" name="requires_invoice">
                            <span>Requires Invoice Details</span>
                        </label>
                        <label class="checkbox-label">
                            <input type="checkbox" id="requires-payment" name="requires_payment">
                            <span>Requires Payment Details</span>
                        </label>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" id="cancel-stage">Cancel</button>
                <button type="submit" class="btn btn-primary">
                    <i class="uil uil-check"></i> Save Changes
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Permissions Modal -->
<div id="permissions-modal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h3 id="permissions-modal-title"><i class="uil uil-shield-check"></i> Edit Permissions</h3>
            <button type="button" class="close-btn">&times;</button>
        </div>
        <form id="permissions-form">
            <input type="hidden" id="permissions-stage-id">
            <div class="modal-body">
                <div class="stage-info" id="stage-info">
                    <!-- Stage info will be loaded here -->
                </div>
                <div class="roles-list" id="roles-list">
                    <% if (locals.roles) { %>
                        <% locals.roles.forEach(role => { %>
                            <label class="role-permission">
                                <input type="checkbox" name="role_<%= role.id %>" value="<%= role.id %>">
                                <span class="role-name"><%= role.name %></span>
                                <span class="role-desc">Can execute this action</span>
                            </label>
                        <% }); %>
                    <% } %>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" id="cancel-permissions">Cancel</button>
                <button type="submit" class="btn btn-primary">
                    <i class="uil uil-check"></i> Save Permissions
                </button>
            </div>
        </form>
    </div>
</div>

<!-- jQuery (required for Select2) -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<!-- Select2 JS -->
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script>
$(document).ready(function() {
    // Initialize Select2 for dropdowns in modal
    function initSelect2() {
        $('.select2-dropdown').select2({
            placeholder: 'Type to search...',
            allowClear: true,
            width: '100%',
            minimumResultsForSearch: 0,
            dropdownParent: $('#stage-modal')
        });
    }
    
    // Initialize when modal is opened
    $(document).on('click', '.btn-edit-stage, [data-action="edit"]', function() {
        setTimeout(function() {
            initSelect2();
        }, 100);
    });
    
    // Also initialize when the modal becomes visible
    const observer = new MutationObserver(function(mutations) {
        mutations.forEach(function(mutation) {
            if (mutation.target.id === 'stage-modal' && mutation.target.style.display !== 'none') {
                setTimeout(initSelect2, 100);
            }
        });
    });
    
    const stageModal = document.getElementById('stage-modal');
    if (stageModal) {
        observer.observe(stageModal, { attributes: true, attributeFilter: ['style'] });
    }
});
</script>

<%- include('partials/footer', { jsFile: 'manage-repair-workflow' }) %>
