<%- include('partials/header', { pageTitle: 'Manage Repair Request Types', cssFile: 'manage-repair-types' }) %>
<%- include('partials/navbar', { user: locals.user }) %>

<div class="main">
    <%- include('partials/sidebar') %>
    <section class="content-area">
        <div class="management-container">
            <div class="page-header">
                <div class="header-left">
                    <h3><i class="uil uil-list-ul"></i> Repair Request Type Management</h3>
                    <p class="subtitle">Manage categories for repair requests</p>
                </div>
                <div class="header-right">
                    <button id="add-type-btn" class="btn btn-add">
                        <i class="uil uil-plus"></i> Add New Type
                    </button>
                </div>
            </div>

            <div id="type-form-modal" class="modal">
                <div class="modal-content">
                    <div class="modal-header">
                        <h4><i class="uil uil-edit"></i> <span id="modal-title">Add New Repair Request Type</span></h4>
                        <button type="button" class="close-btn">&times;</button>
                    </div>
                    <div class="modal-body">
                    <form id="type-form">
                        <input type="hidden" id="type-id" name="id">

                        <div class="form-group">
                            <label for="name">Type Name:<span class="required">*</span></label>
                            <input type="text" id="name" name="name" required placeholder="e.g., Hardware Repair">
                        </div>

                        <div class="form-group">
                            <label for="description">Description:</label>
                            <textarea id="description" name="description" rows="3" placeholder="Brief description of this type..."></textarea>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label for="display_order">Display Order:</label>
                                <input type="number" id="display_order" name="display_order" min="0" value="0">
                            </div>
                            <div class="form-group">
                                <label for="is_active">Active Status:</label>
                                <select id="is_active" name="is_active">
                                    <option value="true">Active</option>
                                    <option value="false">Inactive</option>
                                </select>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary mt-3">
                            <i class="uil uil-save"></i> Save Type
                        </button>
                    </form>
                    </div>
                </div>
            </div>
            
            <div class="list-section mt-4">
                <div class="search-filter-section mb-3">
                    <input type="text" id="search-input" placeholder="Search types..." class="search-input">
                    <label class="checkbox-label">
                        <input type="checkbox" id="show-inactive" checked>
                        <span>Show Inactive</span>
                    </label>
                </div>

                <table id="types-table" class="data-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Description</th>
                            <th>Order</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="types-table-body">
                        <% if (locals.repairTypes && locals.repairTypes.length > 0) { %>
                            <% locals.repairTypes.forEach(type => { %>
                                <tr data-type-id="<%= type.id %>" class="<%= !type.is_active ? 'row-inactive' : '' %>">
                                    <td data-label="ID"><%= type.id %></td>
                                    <td data-label="Name"><%= type.name %></td>
                                    <td data-label="Description"><%= type.description || 'N/A' %></td>
                                    <td data-label="Order"><%= type.display_order || 0 %></td>
                                    <td data-label="Status">
                                        <span class="status-badge <%= type.is_active ? 'status-active' : 'status-inactive' %>">
                                            <%= type.is_active ? 'Active' : 'Inactive' %>
                                        </span>
                                    </td>
                                    <td data-label="Actions">
                                        <button class="btn btn-sm btn-edit" data-id="<%= type.id %>" title="Edit">
                                            <i class="uil uil-edit"></i>
                                        </button>
                                        <button class="btn btn-sm btn-toggle" data-id="<%= type.id %>" data-active="<%= type.is_active %>" title="<%= type.is_active ? 'Deactivate' : 'Activate' %>">
                                            <i class="uil <%= type.is_active ? 'uil-toggle-on' : 'uil-toggle-off' %>"></i>
                                        </button>
                                        <button class="btn btn-sm btn-delete" data-id="<%= type.id %>" title="Delete">
                                            <i class="uil uil-trash-alt"></i>
                                        </button>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr>
                                <td colspan="6" style="text-align:center;">No repair request types found.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
                
                <div class="pagination-controls">
                    <div class="pagination-info">
                        <span id="page-info">Showing all records</span>
                    </div>
                </div>
            </div>

        </div>
    </section>
</div>

<%- include('partials/footer', { jsFile: 'manage-repair-types' }) %>
