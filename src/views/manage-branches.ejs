<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Create / Manage Branches</title>
  <link rel="stylesheet" href="assets/css/branches.css">
  <style></style>
</head>
<body>
  <div class="branch-form-container">
    <h3>Create / Manage Branches</h3>

    <!-- Form -->
    <form id="branch-form">
      <input type="hidden" id="branch_id">

      <div class="form-grid">
        <div class="form-group">
          <label for="name">Name</label>
          <input type="text" id="name" required>
        </div>
        <div class="form-group">
          <label for="location">Location</label>
          <input type="text" id="location" required>
        </div>
      </div>

      <div class="actions">
        <button type="submit" class="btn btn-save">Save</button>
        <button type="button" class="btn btn-cancel" onclick="resetForm()">Cancel</button>
      </div>
      <div id="form-message" class="message"></div>
    </form>

    <!-- User List -->
    <div class="branch-list">
      <h3>Branch List</h3>
      <table>
        <thead>
          <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Location</th>
            <th>Created At</th>
            <th>Updated At</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody id="branch-table-body">
          <tr><td colspan="5" style="text-align:center;color:#888;">Loading...</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <script></script>
  <script src="assets/js/api.js"></script>
  <script src="assets/js/branches.js"></script>
</body>
</html>

