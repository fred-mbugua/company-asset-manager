<%- include('partials/header', { pageTitle: 'Manage Users', cssFile: 'manage-users' }) %>
<%- include('partials/navbar', { user: locals.user }) %>

<div class="main">
    <%- include('partials/sidebar') %>
    <section class="content-area">
        <div class="user-management-container">
            <h3>User Management</h3>
            
            <div class="action-buttons">
                <button id="add-user-btn" class="btn btn-add">
                    <i class="uil-plus"></i> Add New User
                </button>
                
                <% if (locals.user && locals.user.role === 'Admin') { %>
                <div class="bulk-import-actions">
                    <button id="bulk-import-btn" class="btn btn-import">
                        <i class="uil-file-upload-alt"></i> Bulk Import
                    </button>
                    <a href="/api/bulk-user-import/template" class="btn-link">
                        <i class="uil-file-download-alt"></i> Download Template
                    </a>
                    <a href="/users/import-history" class="btn-link">
                        <i class="uil-history"></i> Import History
                    </a>
                </div>
                <% } %>
            </div>

            <!-- Bulk Import Modal -->
            <div id="bulk-import-modal" class="modal">
                <div class="modal-content modal-lg">
                    <span class="close-btn" id="close-import-modal">&times;</span>
                    <h4>Bulk User Import</h4>
                    
                    <div class="import-steps">
                        <div class="step active" data-step="1">
                            <span class="step-number">1</span>
                            <span class="step-title">Upload File</span>
                        </div>
                        <div class="step" data-step="2">
                            <span class="step-number">2</span>
                            <span class="step-title">Preview</span>
                        </div>
                        <div class="step" data-step="3">
                            <span class="step-number">3</span>
                            <span class="step-title">Import</span>
                        </div>
                    </div>

                    <!-- Step 1: Upload -->
                    <div class="import-step-content" id="step-1-content">
                        <div class="upload-section">
                            <div class="upload-area" id="upload-area">
                                <i class="uil uil-cloud-upload"></i>
                                <p>Drag and drop your file here, or click to browse</p>
                                <p class="upload-hint">Supported formats: Excel (.xlsx, .xls) or CSV</p>
                                <input type="file" id="import-file" accept=".xlsx,.xls,.csv" style="display: none;">
                            </div>
                            <div class="file-info" id="file-info" style="display: none;">
                                <i class="uil uil-file-check"></i>
                                <span id="file-name">filename.xlsx</span>
                                <button class="btn btn-sm btn-danger" id="remove-file">
                                    <i class="uil uil-times"></i>
                                </button>
                            </div>
                        </div>
                        <div class="import-actions">
                            <button class="btn btn-secondary" id="cancel-import-btn">Cancel</button>
                            <button class="btn btn-primary" id="preview-btn" disabled>
                                <i class="uil uil-eye"></i> Preview Data
                            </button>
                        </div>
                    </div>

                    <!-- Step 2: Preview -->
                    <div class="import-step-content" id="step-2-content" style="display: none;">
                        <div class="preview-summary">
                            <div class="summary-card summary-valid">
                                <span class="summary-value" id="valid-count">0</span>
                                <span class="summary-label">Valid Records</span>
                            </div>
                            <div class="summary-card summary-invalid">
                                <span class="summary-value" id="invalid-count">0</span>
                                <span class="summary-label">Invalid Records</span>
                            </div>
                        </div>

                        <div class="preview-tabs">
                            <button class="tab-btn active" data-tab="valid">Valid Records</button>
                            <button class="tab-btn" data-tab="invalid">Invalid Records</button>
                        </div>

                        <div class="preview-table-container">
                            <div id="valid-table-container" class="tab-content active">
                                <table class="data-table">
                                    <thead>
                                        <tr>
                                            <th>First Name</th>
                                            <th>Last Name</th>
                                            <th>Email</th>
                                            <th>Phone</th>
                                            <th>Department</th>
                                            <th>Branch</th>
                                            <th>Company</th>
                                        </tr>
                                    </thead>
                                    <tbody id="valid-preview-body">
                                    </tbody>
                                </table>
                            </div>
                            <div id="invalid-table-container" class="tab-content">
                                <table class="data-table">
                                    <thead>
                                        <tr>
                                            <th>Row</th>
                                            <th>Data</th>
                                            <th>Errors</th>
                                        </tr>
                                    </thead>
                                    <tbody id="invalid-preview-body">
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <div class="import-actions">
                            <button class="btn btn-secondary" id="back-to-upload-btn">
                                <i class="uil uil-arrow-left"></i> Back
                            </button>
                            <button class="btn btn-success" id="start-import-btn" disabled>
                                <i class="uil uil-import"></i> Import <span id="import-count">0</span> Users
                            </button>
                        </div>
                    </div>

                    <!-- Step 3: Import Results -->
                    <div class="import-step-content" id="step-3-content" style="display: none;">
                        <div class="import-progress" id="import-progress">
                            <div class="spinner"></div>
                            <p>Importing users... Please wait.</p>
                        </div>
                        
                        <div class="import-results" id="import-results" style="display: none;">
                            <div class="results-summary">
                                <div class="result-card result-success">
                                    <i class="uil uil-check-circle"></i>
                                    <span class="result-value" id="result-success">0</span>
                                    <span class="result-label">Successfully Imported</span>
                                </div>
                                <div class="result-card result-failed">
                                    <i class="uil uil-times-circle"></i>
                                    <span class="result-value" id="result-failed">0</span>
                                    <span class="result-label">Failed</span>
                                </div>
                            </div>

                            <div class="import-note">
                                <i class="uil uil-info-circle"></i>
                                <p>Passwords have been auto-generated for all successfully imported users. 
                                   You can view them in the <a href="/users/import-history">Import History</a> page.</p>
                            </div>

                            <div class="import-actions">
                                <button class="btn btn-secondary" id="close-results-btn">Close</button>
                                <a href="/users/import-history" class="btn btn-primary">
                                    <i class="uil uil-eye"></i> View Import History
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div id="user-form-modal" class="modal">
                <div class="modal-content">
                    <div class="modal-header">
                        <h4><i class="uil-user-plus"></i> <span id="modal-title">Add New User</span></h4>
                        <span class="close-btn">&times;</span>
                    </div>
                    <div class="modal-body">
                        <form id="user-form">
                            <input type="hidden" id="user-id" name="id"> 
                            <input type="hidden" id="employee_id" name="employee_id"> 

                            <div class="form-row">
                                <div class="form-group">
                                    <label for="first_name">First Name <span class="required">*</span></label>
                                    <input type="text" id="first_name" name="first_name" class="form-control" placeholder="Enter first name" required>
                                </div>
                                <div class="form-group">
                                    <label for="middle_name">Middle Name</label>
                                    <input type="text" id="middle_name" name="middle_name" class="form-control" placeholder="Enter middle name">
                                </div>
                            </div>

                            <div class="form-row">
                                <div class="form-group">
                                    <label for="last_name">Last Name <span class="required">*</span></label>
                                    <input type="text" id="last_name" name="last_name" class="form-control" placeholder="Enter last name" required>
                                </div>
                                <div class="form-group">
                                    <label for="phone">Phone <span class="required">*</span></label>
                                    <input type="text" id="phone" name="phone" class="form-control" placeholder="Enter phone number" required>
                                </div>
                            </div>

                            <div class="form-group">
                                <label for="email">Email (Username) <span class="required">*</span></label>
                                <input type="text" id="email" name="email" class="form-control" placeholder="Enter email address" required>
                            </div>

                            <div class="form-row">
                                <div class="form-group">
                                    <label for="password">Password</label>
                                    <div class="password-wrapper">
                                        <input type="password" id="password" name="password" class="form-control" placeholder="Enter password" autocomplete="new-password">
                                        <i class="uil-eye toggle-password" data-target="password"></i>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label for="password_confirm">Confirm Password</label>
                                    <div class="password-wrapper">
                                        <input type="password" id="password_confirm" name="password_confirm" class="form-control" placeholder="Confirm password" autocomplete="new-password">
                                        <i class="uil-eye toggle-password" data-target="password_confirm"></i>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="form-group">
                                <label for="role">Role <span class="required">*</span></label>
                                <div class="searchable-select" data-name="role" data-required="true">
                                    <div class="select-input-wrapper">
                                        <input type="text" class="select-input" placeholder="Search roles..." autocomplete="off">
                                        <i class="uil-angle-down select-arrow"></i>
                                    </div>
                                    <div class="select-dropdown">
                                        <% if (locals.userRoles && locals.userRoles.length) { %>
                                            <% locals.userRoles.forEach(role => { %>
                                                <div class="select-option" data-value="<%= role.id %>"><%= role.name %></div>
                                            <% }); %>
                                        <% } %>
                                    </div>
                                    <input type="hidden" id="role" name="role" required>
                                </div>
                            </div>

                            <div class="form-row">
                                <div class="form-group">
                                    <label for="department_id">Department</label>
                                    <div class="searchable-select" data-name="department_id">
                                        <div class="select-input-wrapper">
                                            <input type="text" class="select-input" placeholder="Search departments..." autocomplete="off">
                                            <i class="uil-angle-down select-arrow"></i>
                                        </div>
                                        <div class="select-dropdown">
                                            <div class="select-option" data-value="">-- None --</div>
                                            <% if (locals.departments && locals.departments.length) { %>
                                                <% locals.departments.forEach(dept => { %>
                                                    <div class="select-option" data-value="<%= dept.id %>"><%= dept.name %></div>
                                                <% }); %>
                                            <% } %>
                                        </div>
                                        <input type="hidden" id="department_id" name="department_id">
                                    </div>
                                </div>
                                
                                <div class="form-group">
                                    <label for="branch_id">Branch</label>
                                    <div class="searchable-select" data-name="branch_id">
                                        <div class="select-input-wrapper">
                                            <input type="text" class="select-input" placeholder="Search branches..." autocomplete="off">
                                            <i class="uil-angle-down select-arrow"></i>
                                        </div>
                                        <div class="select-dropdown">
                                            <div class="select-option" data-value="">-- None --</div>
                                            <% if (locals.locations && locals.locations.length) { %>
                                                <% locals.locations.forEach(branch => { %>
                                                    <div class="select-option" data-value="<%= branch.id %>"><%= branch.name %></div>
                                                <% }); %>
                                            <% } %>
                                        </div>
                                        <input type="hidden" id="branch_id" name="branch_id">
                                    </div>
                                </div>
                            </div>
                            
                            <div class="form-group">
                                <label for="company_id">Company</label>
                                <div class="searchable-select" data-name="company_id">
                                    <div class="select-input-wrapper">
                                        <input type="text" class="select-input" placeholder="Search companies..." autocomplete="off">
                                        <i class="uil-angle-down select-arrow"></i>
                                    </div>
                                    <div class="select-dropdown">
                                        <div class="select-option" data-value="">-- None --</div>
                                        <% if (locals.companies && locals.companies.length) { %>
                                            <% locals.companies.forEach(company => { %>
                                                <div class="select-option" data-value="<%= company.id %>" <%= company.name === 'Jirani Smart' ? 'data-default="true"' : '' %>><%= company.name %></div>
                                            <% }); %>
                                        <% } %>
                                    </div>
                                    <input type="hidden" id="company_id" name="company_id">
                                </div>
                            </div>

                            <button type="submit" class="btn-submit"><i class="uil-check"></i> Save User</button>
                        </form>
                    </div>
                </div>
            </div>
            
            <div class="user-list-section mt-5">
                <h4>Existing Users</h4>
                
                <div class="search-filter-section mb-3">
                    <input type="text" id="search-input" placeholder="Search by email, role, department, or branch..." class="search-input">
                </div>

                <table id="users-table" class="data-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Department</th>
                            <th>Branch</th>
                            <th>Company</th>
                            <th>Employee Link</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="users-table-body">
                        <% if (locals.users && locals.users.length > 0) { %>
                            <% locals.users.forEach(user => { %>
                                <tr data-user-id="<%= user.id %>">
                                    <td data-label="ID"><%= user.id %></td>
                                    <td data-label="Email"><%= user.email %></td>
                                    <td data-label="Role"><%= user.role_name %></td>
                                    <td data-label="Department"><%= user.department_name || 'N/A' %></td>
                                    <td data-label="Branch"><%= user.branch_name || 'N/A' %></td>
                                    <td data-label="Company"><%= user.company_name || 'N/A' %></td>
                                    <td data-label="Employee Link"><%= (user.employee_first_name + ' ' + user.employee_middle_name + ' ' + user.employee_last_name) || 'Unlinked' %></td>
                                    <td data-label="Status"><%= user.is_active === true ? 'Active' : (user.is_active === false ? 'Disabled' : 'N/A') %></td>
                                    <td data-label="Actions">
                                        <% if (locals.user && locals.user.role === 'Admin') { %>
                                        <a href="/profile?userId=<%= user.id %>" class="btn btn-sm btn-view" title="View Profile">
                                            <i class="fa fa-user"></i> View
                                        </a>
                                        <% } %>
                                        <button class="btn btn-sm btn-edit" data-id="<%= user.id %>">Edit</button>
                                        <button class="btn btn-sm btn-reset-password" data-id="<%= user.id %>">Reset Pwd</button>
                                        <button class="btn btn-sm btn-toggle-status" data-id="<%= user.id %>" data-status="<%= user.is_active %>">
                                            <%= user.is_active === true ? 'Disable' : 'Enable' %>
                                        </button>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr>
                                <td colspan="9" style="text-align:center;">No users found.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
                
                <div class="pagination-controls">
                    <div class="pagination-info">
                        <select id="page-size">
                            <option value="10" selected>10 per page</option>
                            <option value="20">20 per page</option>
                            <option value="50">50 per page</option>
                        </select>
                        <span id="page-info">Page 1 of 1 (0 total)</span>
                    </div>
                    <div class="pagination-buttons">
                        <button id="prev-btn" class="btn btn-page" disabled title="Previous Page">
                            <i class="fa fa-chevron-left"></i>
                        </button>
                        <button id="next-btn" class="btn btn-page" disabled title="Next Page">
                            <i class="fa fa-chevron-right"></i>
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </section>
</div>

<%- include('partials/footer', { jsFile: 'manage-users' }) %>