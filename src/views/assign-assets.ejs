<%- include('partials/header', { pageTitle: 'Assign Assets', cssFile: 'assign' }) %>
<!-- Select2 CSS -->
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<%- include('partials/navbar') %>

<div class="main">
    <%- include('partials/sidebar') %>
    <section class="content-wrapper">
        <div class="page-header">
            <h2>Asset Assignment Management</h2>
        </div>

        <div class="form-section">
            
            <form id="assignment-form">
                <div class="form-row">
                    <div class="form-group">
                        <label for="asset_id">Asset</label>
                        <select id="asset_id" class="select2-dropdown" required>
                            <option value="">-- Select Asset --</option>
                            <% locals.assets.forEach(asset => { %>
                            <option value="<%= asset.id %>">
                                <%= asset.asset_tag %> - <%= asset.manufacturer %> <%= asset.model %>
                            </option>
                            <% }); %>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="employee_id">Employee</label>
                        <select id="employee_id" class="select2-dropdown" required>
                            <option value="">-- Select Employee --</option>
                            <% locals.employees.forEach(employee => { %>
                            <option value="<%= employee.id %>">
                                <%= employee.first_name %> <%= employee.last_name %> (<%= employee.emp_email %>)
                            </option>
                            <% }); %>
                        </select>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="assignment_date">Assignment Date</label>
                        <input type="date" id="assignment_date" required 
                               value="<%= new Date().toISOString().substring(0, 10) %>"
                               max="<%= new Date().toISOString().substring(0, 10) %>">
                    </div>
                    
                    <div class="form-group">
                        <label for="notes">Notes</label>
                        <textarea id="notes" rows="3" 
                                  placeholder="Enter assignment details..."></textarea>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">Assign Asset</button>
                </div>
            </form>
        </div>

        <div class="table-section">
            <div class="section-header">
                <h3>Current Assignments</h3>
            </div>
            
            <%- include('partials/asset-assignments', { assignments: locals.assignments }) %>
        </div>
    </section>
</div>

<!-- Return Asset Modal -->
<div id="returnModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h3>Return Asset</h3>
            <span class="close">&times;</span>
        </div>
        <div class="modal-body">
            <form id="return-form">
                <input type="hidden" id="return_assignment_id">
                <div class="form-group">
                    <label for="return_date">Return Date</label>
                    <input type="date" id="return_date" required 
                           value="<%= new Date().toISOString().substring(0, 10) %>"
                           max="<%= new Date().toISOString().substring(0, 10) %>">
                </div>
                <div class="form-group">
                    <label for="return_notes">Return Notes</label>
                    <textarea id="return_notes" rows="3" 
                              placeholder="Enter return details (optional)..."></textarea>
                </div>
                <div class="modal-actions">
                    <button type="submit" class="btn btn-primary">Confirm Return</button>
                    <button type="button" class="btn btn-cancel" id="cancel-return">Cancel</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Select2 JS -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

<script>
$(document).ready(function() {
    $('.select2-dropdown').select2({
        placeholder: 'Select an option',
        allowClear: true,
        width: '100%'
    });
});
</script>
<%- include('partials/footer', { jsFile: 'assign' }) %>
