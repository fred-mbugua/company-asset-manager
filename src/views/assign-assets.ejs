<%- include('partials/header', { pageTitle: 'Assign Assets', cssFile: 'assign' }) %>
<%- include('partials/navbar') %>

<div class="main">
    <%- include('partials/sidebar') %>
    <section class="content-area">
        <div class="assign-container">
            <h3>Assign Asset</h3>

            <form id="assign-form">
                <select id="asset-select" required>
                    <option value="">Select Asset</option>
                    <% locals.assets.forEach(asset => { %>
                        <option value="<%= asset.id %>"><%= asset.asset_tag %> - <%= asset.description %></option>
                    <% }); %>
                </select>
                <select id="employee-select" required>
                    <option value="">Select Employee</option>
                    <% locals.employees.forEach(employee => { %>
                        <option value="<%= employee.id %>"><%= employee.first_name %> <%= employee.last_name %> (<%= employee.email %>)</option>
                    <% }); %>
                </select>
                <button type="submit">Assign</button>
            </form>

            <h3>Current Assignments</h3>
            <table>
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Asset</th>
                        <th>Employee</th>
                        <th>Assigned Date</th>
                        <th>Returned Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="assignment-table-body">
                    <% if (locals.assignments && locals.assignments.length > 0) { %>
                        <% locals.assignments.forEach(assignment => { %>
                            <tr>
                                <td><%= assignment.id %></td>
                                <td><%= assignment.asset_tag %></td>
                                <td><%= assignment.employee_name %></td>
                                <td><%= new Date(assignment.assigned_date).toLocaleDateString() %></td>
                                <td><%= assignment.returned_date ? new Date(assignment.returned_date).toLocaleDateString() : 'N/A' %></td>
                                <td>
                                    <% if (!assignment.returned_date) { %>
                                        <button class="btn btn-return" data-id="<%= assignment.id %>">Return</button>
                                    <% } %>
                                </td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr><td colspan="6" style="text-align:center;color:#888;">No current assignments.</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </section>
</div>

<%- include('partials/footer', { jsFile: 'assign' }) %>