<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Assign Assets</title>
  <link rel="stylesheet" href="assets/css/assign.css">
  <style></style>
</head>
<body>
  <div class="assign-container">
    <h3>Assign Asset</h3>

    <!-- Assignment Form -->
    <form id="assign-form">
      <select id="asset-select" required>
        <option value="">Select Asset</option>
      </select>
      <select id="employee-select" required>
        <option value="">Select Employee</option>
      </select>
      <button type="submit">Assign</button>
    </form>

    <!-- Assigned Assets Table -->
    <h3>Current Assignments</h3>
    <table>
      <thead>
        <tr>
          <th>ID</th>
          <th>Asset</th>
          <th>Employee</th>
          <th>Assigned Date</th>
          <th>Returned Date</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody id="assignment-table-body">
        <tr><td colspan="6" style="text-align:center;color:#888;">Loading...</td></tr>
      </tbody>
    </table>
  </div>
  <script src="assets/js/api.js"></script>
  <script src="assets/js/assign.js"></script>
  <script></script>
</body>
</html>
