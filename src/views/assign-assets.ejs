<%- include('partials/header', { pageTitle: 'Assign Assets', cssFile: 'assign' }) %>
<%- include('partials/navbar') %>

<div class="main">
    <%- include('partials/sidebar') %>
    <section class="content-wrapper">
        <div class="page-header">
            <h2>Asset Assignment Management</h2>
        </div>

        <div class="form-section">
            <div class="section-header">
                <h3>Assign New Asset</h3>
            </div>
            
            <form id="assignment-form">
                <div class="form-row">
                    <div class="form-group">
                        <label for="asset_id">Asset</label>
                        <select id="asset_id" required>
                            <option value="">-- Select Asset --</option>
                            <% locals.assets.forEach(asset => { %>
                            <option value="<%= asset.id %>">
                                <%= asset.asset_tag %> - <%= asset.manufacturer %> <%= asset.model %>
                            </option>
                            <% }); %>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="employee_id">Employee</label>
                        <select id="employee_id" required>
                            <option value="">-- Select Employee --</option>
                            <% locals.employees.forEach(employee => { %>
                            <option value="<%= employee.id %>">
                                <%= employee.first_name %> <%= employee.last_name %> (<%= employee.emp_email %>)
                            </option>
                            <% }); %>
                        </select>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="assignment_date">Assignment Date</label>
                        <input type="date" id="assignment_date" required 
                               value="<%= new Date().toISOString().substring(0, 10) %>">
                    </div>
                    
                    <div class="form-group">
                        <label for="notes">Notes</label>
                        <textarea id="notes" rows="3" 
                                  placeholder="Enter assignment details..."></textarea>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">Assign Asset</button>
                </div>
            </form>
        </div>

        <div class="table-section">
            <div class="section-header">
                <h3>Current Assignments</h3>
            </div>
            
            <%- include('partials/asset-assignments', { assignments: locals.assignments }) %>
        </div>
    </section>
</div>

<%- include('partials/footer', { jsFile: 'assign' }) %>