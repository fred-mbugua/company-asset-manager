<%- include('partials/header', { pageTitle: 'Create Expense', cssFile: 'expenses' }) %>
<!-- Select2 CSS -->
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<%- include('partials/navbar') %>

<div class="main">
  <%- include('partials/sidebar') %>
  <section class="content-wrapper">
    <div class="page-header">
      <h2>Expense Management</h2>
    </div>

    <div class="form-section">
      <div class="section-header">
        <h3>Create New Expense</h3>
      </div>
      
      <form id="expense-form">
        <div class="form-grid">
          <div class="form-group">
            <label for="asset_id">Asset</label>
            <select id="asset_id" name="asset_id" class="select2-dropdown" required style="width: 100%;">
              <option value="">Select Asset</option>
              <% if (locals.assets) { %>
                <% locals.assets.forEach(asset => { %>
                <option value="<%= asset.id %>">
                  <%= asset.asset_tag %> - <%= asset.manufacturer %> - <%= asset.model %>
                </option>
                <% }); %>
              <% } %>
            </select>
          </div>

          <div class="form-group">
            <label for="assigned_employee_display">Assigned Employee</label>
            <input type="text" id="assigned_employee_display" readonly placeholder="Select an asset first" style="background-color: #f5f5f5;">
            <input type="hidden" id="assigned_employee_id" name="assigned_employee_id">
            <small class="form-hint" style="color: #666;">Auto-populated based on asset assignment</small>
          </div>

          <div class="form-group">
            <label for="expense_type">Expense Type</label>
            <select id="expense_type_id" name="expense_type_id" class="select2-dropdown" required style="width: 100%;">
              <option value="">Select Type</option>
              <% if (locals.expenseTypes) { %>
                <% locals.expenseTypes.forEach(type => { %>
                <option value="<%= type.id %>"><%= type.name %></option>
                <% }); %>
              <% } %>
            </select>
          </div>

          <div class="form-group">
            <label for="date">Date</label>
            <input type="date" id="date" name="date" required>
          </div>

          <div class="form-group">
            <label for="amount">Amount</label>
            <input type="number" step="0.01" id="amount" name="amount" required>
          </div>

          <div class="form-group">
            <label for="vendor">Vendor</label>
            <input type="text" id="vendor" name="vendor" required>
          </div>

          <div class="form-group">
            <label for="invoice_number">Invoice Number</label>
            <input type="text" id="invoice_number" name="invoice_number" required>
          </div>

          <div class="form-group notes-field">
            <label for="notes">Notes</label>
            <textarea id="notes" name="notes" rows="3"></textarea>
          </div>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-primary">Save Expense</button>
          <button type="button" class="btn btn-secondary" id="cancel-btn">Cancel</button>
        </div>
      </form>
    </div>

    <div class="table-section">
      <div class="section-header">
        <h3>Expense History</h3>
        <div class="search-container">
          <i class="uil uil-search"></i>
          <input type="text" id="expense-search" placeholder="Search expenses by asset, vendor, invoice, or notes..." />
        </div>
      </div>

      <div class="table-responsive">
        <table id="expense-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Asset</th>
              <th>Model Name</th>
              <th>Date</th>
              <th>Vendor</th>
              <th>Invoice #</th>
              <th>Notes</th>
              <th>Amount</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="expense-table-body">
            <% if (locals.expenses && locals.expenses.length > 0) { %>
              <% locals.expenses.forEach(expense => { %>
              <tr>
                <td><%= expense.id %></td>
                <td><%= expense.asset_tag %> - <%= expense.manufacturer %></td>
                <td><%= expense.model %></td>
                <td><span data-date="<%= expense.expense_date %>"></span></td>
                <td><%= expense.vendor %></td>
                <td><%= expense.invoice_number %></td>
                <td><%= expense.expense_notes || 'N/A' %></td>
                <td>Ksh. <%= expense.expense_amount.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ',') %></td>
                <td>
                  <div style="display: flex; gap: 5px;">
                    <button class="btn btn-edit" onclick="showExpenseDetails(<%= expense.id %>)">View/Attachments</button>
                    <% if (locals.user && (locals.user.role === 'Admin' || (locals.userPermissions && locals.userPermissions.EXPENSES && locals.userPermissions.EXPENSES.actions.includes('delete')))) { %>
                      <button class="btn btn-danger btn-delete" onclick="deleteExpense(<%= expense.id %>)">Delete</button>
                    <% } %>
                  </div>
                </td>
              </tr>
              <% }); %>
              <tr id="subtotal-row">
                <td colspan="7" class="no-data" style="text-align: right;">Sub total: </td>
                <td class="subtotal">Ksh. <%= locals.expenses[0].expense_subtotal.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ',') %></td>
              </tr>
            <% } else { %>
              <tr>
                <td colspan="9" class="no-data">No expenses recorded</td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
      
      <div class="pagination-controls">
        <div class="pagination-info">
          <select id="page-size">
            <option value="10" selected>10 per page</option>
            <option value="20">20 per page</option>
            <option value="50">50 per page</option>
          </select>
          <span id="page-info">Page 1 of 1 (0 total)</span>
        </div>
        <div class="pagination-buttons">
          <button id="prev-btn" class="btn btn-page" disabled title="Previous Page">
            <i class="fa fa-chevron-left"></i>
          </button>
          <button id="next-btn" class="btn btn-page" disabled title="Next Page">
            <i class="fa fa-chevron-right"></i>
          </button>
        </div>
      </div>
    </div>
  </section>
</div>

<!-- Expense Detail Modal -->
<div id="expenseDetailModal" class="modal">
  <div class="modal-content" style="max-width: 900px;">
    <div class="modal-header">
      <h3>Expense Details & Attachments</h3>
      <span class="close" onclick="closeExpenseDetail()">&times;</span>
    </div>
    <div class="modal-body">
      <div id="expense-detail-content">
        <p style="text-align: center; color: #888;">Loading...</p>
      </div>
    </div>
  </div>
</div>

<!-- jQuery (required for Select2) -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<!-- Select2 JS -->
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script src="/assets/js/attachmentManager.js"></script>
<script>
$(document).ready(function() {
    $('.select2-dropdown').select2({
        placeholder: 'Type to search...',
        allowClear: true,
        width: 'style',
        minimumResultsForSearch: 0
    });
});
</script>

<%- include('partials/footer', { jsFile: 'expenses' }) %>