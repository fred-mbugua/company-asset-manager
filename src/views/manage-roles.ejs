<%- include('partials/header', { pageTitle: 'Manage Roles', cssFile: 'manage-roles' }) %>
<%- include('partials/navbar', { user: locals.user }) %>

<div class="main">
    <%- include('partials/sidebar') %>
    <section class="content-area">
        <div class="management-container">
            <h3>User Role Management</h3>
            
            <button id="add-role-btn" class="btn btn-add">
                <i class="uil-plus"></i> Add New Role
            </button>

            <!-- Role Form Modal -->
            <div id="role-form-modal" class="modal">
                <div class="modal-content">
                    <div class="modal-header">
                        <h4><i class="uil uil-user-plus"></i> <span id="modal-title">Add New Role</span></h4>
                        <button type="button" class="close-btn">&times;</button>
                    </div>
                    <div class="modal-body">
                        <form id="role-form">
                            <input type="hidden" id="role-id" name="id">

                            <div class="form-group">
                                <label for="role-name">Role Name:<span class="required">*</span></label>
                                <input type="text" id="role-name" name="name" required placeholder="e.g., Finance Manager">
                            </div>

                            <div class="form-group">
                                <label for="role-description">Description:</label>
                                <textarea id="role-description" name="description" rows="3" placeholder="Brief description of this role's purpose..."></textarea>
                            </div>

                            <div class="form-check mt-3">
                                <input type="checkbox" id="role-is-active" name="is_active" checked>
                                <label for="role-is-active">Active</label>
                                <small class="form-hint">Inactive roles cannot be assigned to users</small>
                            </div>

                            <button type="submit" class="btn btn-primary mt-3">
                                <i class="uil uil-save"></i> Save Role
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Delete Confirmation Modal -->
            <div id="delete-modal" class="modal">
                <div class="modal-content modal-sm">
                    <div class="modal-header modal-header-danger">
                        <h4><i class="uil uil-exclamation-triangle"></i> Confirm Delete</h4>
                        <button type="button" class="close-btn">&times;</button>
                    </div>
                    <div class="modal-body">
                        <div class="delete-message">
                            <p id="delete-message">Are you sure you want to delete this role?</p>
                        </div>
                        <div class="modal-actions">
                            <button type="button" class="btn btn-secondary" id="cancel-delete-btn">Cancel</button>
                            <button type="button" class="btn btn-delete" id="confirm-delete-btn">
                                <i class="uil uil-trash"></i> Delete
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Permissions Modal -->
            <div id="permissions-modal" class="modal">
                <div class="modal-content modal-lg">
                    <div class="modal-header">
                        <h4><i class="uil uil-shield-check"></i> Manage Permissions for <span id="permissions-role-name"></span></h4>
                        <button type="button" class="close-btn">&times;</button>
                    </div>
                    <div class="modal-body">
                        <div class="permissions-modal-content">
                            <div class="permissions-info">
                                <p>Configure which modules and actions this role can access. Branch-level access restricts data to the user's assigned branch.</p>
                            </div>

                            <div class="permissions-legend">
                                <span class="legend-item"><i class="uil-eye"></i> Read</span>
                                <span class="legend-item"><i class="uil-plus"></i> Create</span>
                                <span class="legend-item"><i class="uil-edit"></i> Update</span>
                                <span class="legend-item"><i class="uil-trash-alt"></i> Delete</span>
                                <span class="legend-item branch-legend"><i class="uil-building"></i> Branch Only</span>
                            </div>

                            <div id="permissions-loading" class="loading-state">
                                <i class="uil-spinner-alt spin"></i> Loading permissions...
                            </div>

                            <div id="permissions-grid" class="permissions-grid"></div>

                            <div class="modal-actions mt-3">
                                <button type="button" class="btn btn-secondary" id="cancel-permissions-btn">Cancel</button>
                                <button type="button" class="btn btn-primary" id="save-permissions-btn">
                                    <i class="uil-save"></i> Save Permissions
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="list-section mt-5">
                <h4>Existing Roles</h4>
                
                <div class="search-filter-section mb-3">
                    <input type="text" id="search-input" placeholder="Search by name or description..." class="search-input">
                    <select id="status-filter" class="filter-select">
                        <option value="all">All Status</option>
                        <option value="active">Active Only</option>
                        <option value="inactive">Inactive Only</option>
                    </select>
                </div>

                <table id="roles-table" class="data-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Description</th>
                            <th>Users</th>
                            <th>Permissions</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="roles-table-body">
                        <tr>
                            <td colspan="7" style="text-align:center;">
                                <i class="uil-spinner-alt spin"></i> Loading roles...
                            </td>
                        </tr>
                    </tbody>
                </table>
                
                <div class="pagination-controls">
                    <div class="pagination-info">
                        <select id="page-size">
                            <option value="10" selected>10 per page</option>
                            <option value="20">20 per page</option>
                            <option value="50">50 per page</option>
                        </select>
                        <span id="page-info">Page 1 of 1 (0 total)</span>
                    </div>
                    <div class="pagination-buttons">
                        <button id="prev-btn" class="btn btn-page" disabled title="Previous Page">
                            <i class="fa fa-chevron-left"></i>
                        </button>
                        <button id="next-btn" class="btn btn-page" disabled title="Next Page">
                            <i class="fa fa-chevron-right"></i>
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </section>
</div>

<style>
/* Permissions Modal Styles */
.modal-lg {
    max-width: 900px;
    width: 95%;
}

.permissions-modal-content {
    max-height: 70vh;
    overflow-y: auto;
}

.permissions-info {
    padding: 12px 16px;
    background: #f0f7ff;
    border-radius: 8px;
    margin-bottom: 16px;
    color: #1e40af;
}

.permissions-legend {
    display: flex;
    gap: 20px;
    padding: 10px 16px;
    background: #f8f9fa;
    border-radius: 6px;
    margin-bottom: 16px;
    flex-wrap: wrap;
}

.legend-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: #666;
}

.legend-item.branch-legend {
    color: #f59e0b;
}

.permissions-grid {
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.perm-module-card {
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    overflow: hidden;
}

.perm-module-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 16px;
    background: #f5f7fa;
}

.perm-module-name {
    font-weight: 600;
    color: #333;
}

.perm-module-code {
    font-size: 11px;
    color: #888;
    font-family: monospace;
}

.perm-actions {
    display: flex;
    gap: 8px;
    padding: 12px 16px;
    flex-wrap: wrap;
}

.perm-action-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: 8px 12px;
    border: 1px solid #ddd;
    border-radius: 6px;
    background: white;
    cursor: pointer;
    transition: all 0.2s;
    min-width: 60px;
}

.perm-action-btn:hover {
    border-color: #667eea;
    background: #f8f9ff;
}

.perm-action-btn.active {
    border-color: #667eea;
    background: #667eea;
    color: white;
}

.perm-action-btn i {
    font-size: 16px;
}

.perm-action-btn span {
    font-size: 10px;
    text-transform: uppercase;
}

.perm-branch-toggle {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 12px;
    border: 1px solid #f59e0b;
    border-radius: 6px;
    background: white;
    cursor: pointer;
    margin-left: auto;
}

.perm-branch-toggle:hover {
    background: #fffbeb;
}

.perm-branch-toggle.active {
    background: #f59e0b;
    color: white;
}

.perm-branch-toggle i {
    color: #f59e0b;
}

.perm-branch-toggle.active i {
    color: white;
}

.loading-state {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px;
    color: #666;
}

.loading-state.hidden {
    display: none;
}

.btn-permissions {
    background: #8b5cf6;
    color: white;
}

.btn-permissions:hover {
    background: #7c3aed;
}

/* Module group styling for permission grid */
.module-group {
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 8px;
}

.module-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 16px;
    background: #f5f7fa;
    flex-wrap: wrap;
    gap: 10px;
}

.module-info {
    display: flex;
    align-items: center;
    gap: 8px;
}

.module-info i {
    color: #667eea;
    font-size: 18px;
}

.module-name {
    font-weight: 600;
    color: #333;
}

.child-count {
    font-size: 11px;
    color: #888;
}

.module-children {
    padding: 8px 16px;
    background: white;
}

.child-module {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 0;
    border-bottom: 1px solid #eee;
    flex-wrap: wrap;
    gap: 10px;
}

.child-module:last-child {
    border-bottom: none;
}

.child-module-name {
    display: flex;
    align-items: center;
    gap: 6px;
    color: #555;
}

.child-module-name i {
    color: #999;
}

/* Permission toggle buttons */
.permission-toggles {
    display: flex;
    gap: 6px;
}

.permission-toggle {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    padding: 6px 10px;
    border: 1px solid #ddd;
    border-radius: 6px;
    background: white;
    cursor: pointer;
    transition: all 0.2s;
    min-width: 50px;
}

.permission-toggle:hover:not(:disabled) {
    border-color: #667eea;
    background: #f8f9ff;
}

.permission-toggle.active {
    border-color: #667eea;
    background: #667eea;
    color: white;
}

.permission-toggle:disabled {
    opacity: 0.4;
    cursor: not-allowed;
    background: #f5f5f5;
}

.permission-toggle i {
    font-size: 14px;
}

.permission-toggle span {
    font-size: 9px;
    text-transform: uppercase;
    font-weight: 500;
}

.permissions-error {
    padding: 30px;
    text-align: center;
    color: #dc2626;
}

.permissions-error i {
    font-size: 32px;
    margin-bottom: 10px;
}

.no-modules {
    padding: 30px;
    text-align: center;
    color: #888;
}
</style>

<%- include('partials/footer', { jsFile: 'manage-roles' }) %>