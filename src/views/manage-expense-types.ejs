<%- include('partials/header', { pageTitle: 'Manage Expense Types', cssFile: 'manage-expense-types' }) %>
<%- include('partials/navbar', { user: locals.user }) %>

<div class="main">
    <%- include('partials/sidebar') %>
    <section class="content-area">
        <div class="management-container">
            <h3>Expense Type Management</h3>
            
            <button id="add-type-btn" class="btn btn-add">
                <i class="uil-plus"></i> Add New Expense Type
            </button>

            <div id="type-form-modal" class="modal">
                <div class="modal-content">
                    <span class="close-btn">&times;</span>
                    <h4><span id="modal-title">Add New Expense Type</span></h4>
                    
                    <form id="type-form">
                        <input type="hidden" id="type-id" name="id">

                        <label for="name">Type Name:<span class="required">*</span></label>
                        <input type="text" id="name" name="name" required>

                        <label for="description">Description:</label>
                        <textarea id="description" name="description" rows="3"></textarea>

                        <button type="submit" class="btn btn-primary mt-3">
                            <i class="uil-save"></i> Save Type
                        </button>
                    </form>
                </div>
            </div>
            
            <div class="list-section mt-5">
                <h4>Existing Expense Types</h4>
                
                <div class="search-filter-section mb-3">
                    <input type="text" id="search-input" placeholder="Search by name..." class="search-input">
                </div>

                <table id="types-table" class="data-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Description</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="types-table-body">
                        <% if (locals.expenseTypes && locals.expenseTypes.length > 0) { %>
                            <% locals.expenseTypes.forEach(type => { %>
                                <tr data-type-id="<%= type.id %>">
                                    <td data-label="ID"><%= type.id %></td>
                                    <td data-label="Name"><%= type.name %></td>
                                    <td data-label="Description"><%= type.description || 'N/A' %></td>
                                    <td data-label="Actions">
                                        <button class="btn btn-sm btn-edit" data-id="<%= type.id %>">Edit</button>
                                        <button class="btn btn-sm btn-delete" data-id="<%= type.id %>">Delete</button>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr>
                                <td colspan="4" style="text-align:center;">No expense types found.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
                
                <div class="pagination-controls">
                    <div class="pagination-info">
                        <select id="page-size">
                            <option value="10" selected>10 per page</option>
                            <option value="20">20 per page</option>
                            <option value="50">50 per page</option>
                        </select>
                        <span id="page-info">Page 1 of 1 (0 total)</span>
                    </div>
                    <div class="pagination-buttons">
                        <button id="prev-btn" class="btn btn-page" disabled title="Previous Page">
                            <i class="fa fa-chevron-left"></i>
                        </button>
                        <button id="next-btn" class="btn btn-page" disabled title="Next Page">
                            <i class="fa fa-chevron-right"></i>
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </section>
</div>

<%- include('partials/footer', { jsFile: 'manage-expense-types' }) %>
