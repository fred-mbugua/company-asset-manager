<%- include('partials/header', { pageTitle: 'Repair Summary Report', cssFile: 'expenses-report' }) %>
<!-- Select2 CSS -->
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<%- include('partials/navbar', { user: locals.user }) %>

<div class="main">
    <%- include('partials/sidebar') %>
    <section class="content-area">
        <div class="report-container">
            <h3>Repair Expense Summary Report</h3>
            <p class="report-description">Summary of repair expenses by asset - showing highest cost assets first</p>

            <div class="filters">
                <div class="filter-row">
                    <div class="filter-group">
                        <label>Asset Tag:</label>
                        <input type="text" id="filter-asset-tag" placeholder="Search asset tag...">
                    </div>
                    <div class="filter-group date-range">
                        <label>Date Range:</label>
                        <div class="date-inputs">
                            <input type="date" id="filter-from-date" placeholder="From Date">
                            <span class="date-separator">to</span>
                            <input type="date" id="filter-to-date" placeholder="To Date">
                        </div>
                    </div>
                    
                    <div class="filter-actions">
                        <button class="btn btn-view" id="search-btn">Search</button>
                        <button class="btn btn-secondary" id="clear-btn">Clear</button>
                        <button class="btn btn-export" id="export-btn">Export to Excel</button>
                    </div>
                </div>
            </div>

            <!-- Summary Stats -->
            <div class="summary-stats" id="summary-stats" style="display: none;">
                <div class="stat-card">
                    <h4>Total Repair Cost</h4>
                    <span id="total-repair-cost" class="stat-value">-</span>
                </div>
                <div class="stat-card">
                    <h4>Total Assets</h4>
                    <span id="total-assets" class="stat-value">-</span>
                </div>
                <div class="stat-card">
                    <h4>Total Repairs</h4>
                    <span id="total-repairs" class="stat-value">-</span>
                </div>
            </div>

            <div class="table-wrapper">
                <table class="report-table">
                    <thead>
                        <tr>
                            <th>Staff</th>
                            <th>Company</th>
                            <th>Asset Tag</th>
                            <th>Location</th>
                            <th>Model</th>
                            <th>Status</th>
                            <th>Asset Type</th>
                            <th>Repair Count</th>
                            <th>Total Repair Amount</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="repair-summary-table-body">
                        <tr>
                            <td colspan="10" class="no-data">Select a date range and click Search to generate report</td>
                        </tr>
                    </tbody>
                    <tfoot id="summary-footer" style="display: none;">
                        <tr>
                            <td colspan="7" class="total-label"><strong>Grand Total:</strong></td>
                            <td id="footer-repair-count"><strong>-</strong></td>
                            <td id="footer-total-amount"><strong>-</strong></td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>

            <div class="pagination-controls" id="pagination-container" style="display: none;">
                <div class="pagination-info">
                    <select id="page-size">
                        <option value="10">10 per page</option>
                        <option value="20" selected>20 per page</option>
                        <option value="50">50 per page</option>
                        <option value="100">100 per page</option>
                    </select>
                    <span id="page-info">Page 1 of 1 (0 total)</span>
                </div>
                <div class="pagination-buttons">
                    <button id="prev-btn" class="btn btn-page" disabled title="Previous Page">
                        <i class="fa fa-chevron-left"></i>
                    </button>
                    <button id="next-btn" class="btn btn-page" disabled title="Next Page">
                        <i class="fa fa-chevron-right"></i>
                    </button>
                </div>
            </div>
        </div>
    </section>
</div>

<!-- Expense History Modal -->
<div id="expenseHistoryModal" class="modal">
    <div class="modal-content expense-history-modal">
        <div class="modal-header">
            <h3>Repair Expense History</h3>
            <span class="close" onclick="closeExpenseHistoryModal()">&times;</span>
        </div>
        <div class="modal-body">
            <div class="expense-asset-info" id="expense-asset-info">
                <p><strong>Asset:</strong> <span id="modal-asset-tag">-</span></p>
                <p><strong>Model:</strong> <span id="modal-asset-model">-</span></p>
            </div>
            <div class="expense-history-content" id="expense-history-content">
                <p style="text-align: center; color: #888;">Loading expenses...</p>
            </div>
        </div>
    </div>
</div>

<!-- Expense Detail Modal -->
<div id="expenseDetailModal" class="modal">
    <div class="modal-content expense-detail-modal">
        <div class="modal-header">
            <h3>Expense Details</h3>
            <span class="close" onclick="closeExpenseDetailModal()">&times;</span>
        </div>
        <div class="modal-body">
            <div id="expense-detail-content">
                <p style="text-align: center; color: #888;">Loading...</p>
            </div>
        </div>
    </div>
</div>

<!-- Attachments Modal -->
<div id="attachmentsModal" class="modal">
    <div class="modal-content attachments-modal">
        <div class="modal-header">
            <h3>Expense Attachments</h3>
            <span class="close" onclick="closeAttachmentsModal()">&times;</span>
        </div>
        <div class="modal-body">
            <div id="attachments-content">
                <p style="text-align: center; color: #888;">Loading attachments...</p>
            </div>
        </div>
    </div>
</div>

<!-- Repair Request Attachments Modal -->
<div id="repairAttachmentsModal" class="modal">
    <div class="modal-content attachments-modal">
        <div class="modal-header">
            <h3><i class="fa fa-wrench"></i> Repair Request Documents</h3>
            <span class="close" onclick="closeRepairAttachmentsModal()">&times;</span>
        </div>
        <div class="modal-body">
            <div id="repair-request-info" style="background: #e8f4fd; padding: 10px; border-radius: 4px; margin-bottom: 15px;">
                <strong>Request:</strong> <span id="repair-request-number">-</span>
            </div>
            <div id="repair-attachments-content">
                <p style="text-align: center; color: #888;">Loading attachments...</p>
            </div>
        </div>
    </div>
</div>

<!-- Select2 JS -->
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script src="/js/api.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    const searchBtn = document.getElementById('search-btn');
    const clearBtn = document.getElementById('clear-btn');
    const exportBtn = document.getElementById('export-btn');
    const tableBody = document.getElementById('repair-summary-table-body');
    const summaryStats = document.getElementById('summary-stats');
    const summaryFooter = document.getElementById('summary-footer');
    const paginationContainer = document.getElementById('pagination-container');
    const pageSizeSelect = document.getElementById('page-size');
    const prevBtn = document.getElementById('prev-btn');
    const nextBtn = document.getElementById('next-btn');
    const pageInfo = document.getElementById('page-info');

    let currentPage = 1;
    let totalPages = 1;
    let totalCount = 0;

    // Currency formatter
    const currencyFormatter = new Intl.NumberFormat('en-KE', {
        style: 'currency',
        currency: 'KES'
    });

    // Get current filters
    function getFilters() {
        return {
            from_date: document.getElementById('filter-from-date').value,
            to_date: document.getElementById('filter-to-date').value,
            asset_tag: document.getElementById('filter-asset-tag').value.trim()
        };
    }

    // Search button click handler
    searchBtn.addEventListener('click', function() {
        currentPage = 1;
        fetchData();
    });

    // Clear button click handler
    clearBtn.addEventListener('click', function() {
        document.getElementById('filter-from-date').value = '';
        document.getElementById('filter-to-date').value = '';
        document.getElementById('filter-asset-tag').value = '';
        currentPage = 1;
        hideSummary();
        tableBody.innerHTML = '<tr><td colspan="10" class="no-data">Select a date range and click Search to generate report</td></tr>';
    });

    // Page size change handler
    pageSizeSelect.addEventListener('change', function() {
        currentPage = 1;
        fetchData();
    });

    // Pagination button handlers
    prevBtn.addEventListener('click', function() {
        if (currentPage > 1) {
            currentPage--;
            fetchData();
        }
    });

    nextBtn.addEventListener('click', function() {
        if (currentPage < totalPages) {
            currentPage++;
            fetchData();
        }
    });

    async function fetchData() {
        const filters = getFilters();
        const limit = parseInt(pageSizeSelect.value);
        const offset = (currentPage - 1) * limit;

        const params = new URLSearchParams();
        if (filters.from_date) params.append('from_date', filters.from_date);
        if (filters.to_date) params.append('to_date', filters.to_date);
        if (filters.asset_tag) params.append('asset_tag', filters.asset_tag);
        params.append('limit', limit);
        params.append('offset', offset);

        try {
            searchBtn.disabled = true;
            searchBtn.textContent = 'Loading...';
            tableBody.innerHTML = '<tr><td colspan="10" class="no-data">Loading...</td></tr>';

            const response = await API.get(`/reports/repair-summary?${params.toString()}`);
            
            if (response.success && response.data) {
                totalCount = response.data.totalCount;
                totalPages = Math.ceil(totalCount / limit);

                renderTable(response.data.summary);
                updateSummaryStats(response.data.summary);
                updatePaginationControls();
                paginationContainer.style.display = 'flex';
            } else {
                tableBody.innerHTML = '<tr><td colspan="10" class="no-data">No repair expenses found for the selected criteria</td></tr>';
                hideSummary();
            }
        } catch (error) {
            console.error('Error fetching repair summary:', error);
            tableBody.innerHTML = '<tr><td colspan="10" class="no-data">Error loading data. Please try again.</td></tr>';
            hideSummary();
        } finally {
            searchBtn.disabled = false;
            searchBtn.textContent = 'Search';
        }
    }

    // Export button click handler
    exportBtn.addEventListener('click', function() {
        const filters = getFilters();
        const params = new URLSearchParams();
        if (filters.from_date) params.append('from_date', filters.from_date);
        if (filters.to_date) params.append('to_date', filters.to_date);
        if (filters.asset_tag) params.append('asset_tag', filters.asset_tag);
        window.location.href = `/api/reports/repair-summary/export?${params.toString()}`;
    });

    function renderTable(data) {
        if (!data || data.length === 0) {
            tableBody.innerHTML = '<tr><td colspan="10" class="no-data">No repair expenses found for the selected criteria</td></tr>';
            hideSummary();
            return;
        }

        let html = '';
        data.forEach(item => {
            html += `
                <tr>
                    <td>${escapeHtml(item.staff_name)}</td>
                    <td>${escapeHtml(item.company)}</td>
                    <td>${escapeHtml(item.asset_tag)}</td>
                    <td>${escapeHtml(item.location || 'N/A')}</td>
                    <td>${escapeHtml(item.model || 'N/A')}</td>
                    <td><span class="status-badge status-${item.status?.toLowerCase().replace(/\s+/g, '-')}">${escapeHtml(item.status)}</span></td>
                    <td>${escapeHtml(item.asset_type)}</td>
                    <td class="text-center">${item.repair_count}</td>
                    <td class="text-right amount-highlight">${item.total_repair_amount}</td>
                    <td class="actions-cell">
                        <button class="btn btn-sm btn-view" onclick="showExpenseHistory(${item.asset_id}, '${escapeHtml(item.asset_tag)}', '${escapeHtml(item.model || 'N/A')}')">
                            <i class="fa fa-history"></i> View History
                        </button>
                    </td>
                </tr>
            `;
        });
        tableBody.innerHTML = html;
    }

    function updateSummaryStats(data) {
        if (!data || data.length === 0) {
            hideSummary();
            return;
        }

        // Calculate totals
        let totalCost = 0;
        let totalRepairs = 0;

        data.forEach(item => {
            totalCost += item.total_repair_amount_raw || 0;
            totalRepairs += parseInt(item.repair_count) || 0;
        });

        // Update stats display
        document.getElementById('total-repair-cost').textContent = currencyFormatter.format(totalCost);
        document.getElementById('total-assets').textContent = totalCount;
        document.getElementById('total-repairs').textContent = totalRepairs;

        // Update footer
        document.getElementById('footer-repair-count').innerHTML = `<strong>${totalRepairs}</strong>`;
        document.getElementById('footer-total-amount').innerHTML = `<strong>${currencyFormatter.format(totalCost)}</strong>`;

        // Show summary elements
        summaryStats.style.display = 'flex';
        summaryFooter.style.display = '';
    }

    function updatePaginationControls() {
        const limit = parseInt(pageSizeSelect.value);
        const start = (currentPage - 1) * limit + 1;
        const end = Math.min(currentPage * limit, totalCount);
        
        pageInfo.textContent = `Page ${currentPage} of ${totalPages} (${start}-${end} of ${totalCount} records)`;
        prevBtn.disabled = currentPage === 1;
        nextBtn.disabled = currentPage >= totalPages;
    }

    function hideSummary() {
        summaryStats.style.display = 'none';
        summaryFooter.style.display = 'none';
        paginationContainer.style.display = 'none';
    }

    function escapeHtml(text) {
        if (!text) return '';
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }

    // Make functions globally available
    window.getFilters = getFilters;
    window.escapeHtml = escapeHtml;
    window.currencyFormatter = currencyFormatter;
});

// Show Expense History Modal
async function showExpenseHistory(assetId, assetTag, model) {
    const modal = document.getElementById('expenseHistoryModal');
    const content = document.getElementById('expense-history-content');
    document.getElementById('modal-asset-tag').textContent = assetTag;
    document.getElementById('modal-asset-model').textContent = model;

    modal.style.display = 'block';
    content.innerHTML = '<p style="text-align: center; color: #888;">Loading expenses...</p>';

    try {
        const filters = window.getFilters();
        const params = new URLSearchParams();
        if (filters.from_date) params.append('from_date', filters.from_date);
        if (filters.to_date) params.append('to_date', filters.to_date);

        const response = await API.get(`/reports/repair-summary/asset/${assetId}?${params.toString()}`);
        
        if (response.success && response.data && response.data.length > 0) {
            let html = `
                <div class="expense-history-table-wrapper">
                    <table class="expense-history-table">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Type</th>
                                <th>Amount</th>
                                <th>Vendor</th>
                                <th>Invoice #</th>
                                <th>Assigned To</th>
                                <th>Notes</th>
                                <th>Expense Docs</th>
                                <th>Repair Docs</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
            `;

            response.data.forEach(expense => {
                const repairAttachmentCount = parseInt(expense.repair_attachment_count) || 0;
                html += `
                    <tr>
                        <td>${expense.date_formatted}</td>
                        <td>${window.escapeHtml(expense.expense_type)}</td>
                        <td class="amount-highlight">${expense.amount_formatted}</td>
                        <td>${window.escapeHtml(expense.vendor || 'N/A')}</td>
                        <td>${window.escapeHtml(expense.invoice_number || 'N/A')}</td>
                        <td>${window.escapeHtml(expense.assigned_to)}</td>
                        <td class="notes-cell">${window.escapeHtml(expense.notes || 'N/A')}</td>
                        <td class="text-center">
                            ${expense.attachment_count > 0 
                                ? `<button class="btn btn-sm btn-attachment" onclick="showExpenseAttachments(${expense.id})">
                                    <i class="fa fa-paperclip"></i> ${expense.attachment_count}
                                   </button>`
                                : '<span class="text-muted">None</span>'
                            }
                        </td>
                        <td class="text-center">
                            ${expense.repair_request_id && repairAttachmentCount > 0
                                ? `<button class="btn btn-sm btn-repair-docs" onclick="showRepairAttachments(${expense.repair_request_id}, '${window.escapeHtml(expense.repair_request_number || '')}')">
                                    <i class="fa fa-wrench"></i> ${repairAttachmentCount}
                                   </button>`
                                : (expense.repair_request_id ? '<span class="text-muted">None</span>' : '<span class="text-muted">N/A</span>')
                            }
                        </td>
                        <td>
                            <button class="btn btn-sm btn-info" onclick="showExpenseDetail(${expense.id})">
                                <i class="fa fa-eye"></i> Details
                            </button>
                        </td>
                    </tr>
                `;
            });

            html += `
                        </tbody>
                    </table>
                </div>
                <div class="expense-history-summary">
                    <strong>Total Expenses:</strong> ${response.data.length} | 
                    <strong>Total Amount:</strong> ${window.currencyFormatter.format(response.data.reduce((sum, e) => sum + parseFloat(e.amount), 0))}
                </div>
            `;

            content.innerHTML = html;
        } else {
            content.innerHTML = '<p style="text-align: center; color: #888;">No repair expenses found for this asset.</p>';
        }
    } catch (error) {
        console.error('Error fetching expense history:', error);
        content.innerHTML = '<p style="text-align: center; color: red;">Error loading expense history. Please try again.</p>';
    }
}

function closeExpenseHistoryModal() {
    document.getElementById('expenseHistoryModal').style.display = 'none';
}

// Show Expense Detail Modal
async function showExpenseDetail(expenseId) {
    const modal = document.getElementById('expenseDetailModal');
    const content = document.getElementById('expense-detail-content');
    
    modal.style.display = 'block';
    content.innerHTML = '<p style="text-align: center; color: #888;">Loading...</p>';

    try {
        const response = await API.get(`/expenses/${expenseId}`);
        
        if (response.data) {
            const expense = response.data;
            content.innerHTML = `
                <div class="expense-detail-grid">
                    <div class="detail-section">
                        <h4>Expense Information</h4>
                        <div class="detail-row">
                            <span class="detail-label">Expense ID:</span>
                            <span class="detail-value">#${expense.id}</span>
                        </div>
                        <div class="detail-row">
                            <span class="detail-label">Date:</span>
                            <span class="detail-value">${DateUtils.formatDate(expense.date)}</span>
                        </div>
                        <div class="detail-row">
                            <span class="detail-label">Type:</span>
                            <span class="detail-value">${expense.expense_type_name || 'N/A'}</span>
                        </div>
                        <div class="detail-row">
                            <span class="detail-label">Amount:</span>
                            <span class="detail-value amount-highlight">${window.currencyFormatter.format(expense.amount)}</span>
                        </div>
                        <div class="detail-row">
                            <span class="detail-label">Vendor:</span>
                            <span class="detail-value">${expense.vendor || 'N/A'}</span>
                        </div>
                        <div class="detail-row">
                            <span class="detail-label">Invoice Number:</span>
                            <span class="detail-value">${expense.invoice_number || 'N/A'}</span>
                        </div>
                    </div>
                    <div class="detail-section">
                        <h4>Asset Information</h4>
                        <div class="detail-row">
                            <span class="detail-label">Asset Tag:</span>
                            <span class="detail-value">${expense.asset_tag || 'N/A'}</span>
                        </div>
                        <div class="detail-row">
                            <span class="detail-label">Manufacturer:</span>
                            <span class="detail-value">${expense.manufacturer || 'N/A'}</span>
                        </div>
                        <div class="detail-row">
                            <span class="detail-label">Model:</span>
                            <span class="detail-value">${expense.model || 'N/A'}</span>
                        </div>
                    </div>
                    <div class="detail-section">
                        <h4>Assignment Information</h4>
                        <div class="detail-row">
                            <span class="detail-label">Assigned To:</span>
                            <span class="detail-value">${expense.assigned_employee_name || 'Unassigned'}</span>
                        </div>
                        <div class="detail-row">
                            <span class="detail-label">Company:</span>
                            <span class="detail-value">${expense.employee_company || 'N/A'}</span>
                        </div>
                    </div>
                    <div class="detail-section full-width">
                        <h4>Notes</h4>
                        <p class="notes-content">${expense.notes || 'No notes provided'}</p>
                    </div>
                </div>
            `;
        } else {
            content.innerHTML = '<p style="text-align: center; color: red;">Expense not found.</p>';
        }
    } catch (error) {
        console.error('Error fetching expense details:', error);
        content.innerHTML = '<p style="text-align: center; color: red;">Error loading expense details. Please try again.</p>';
    }
}

function closeExpenseDetailModal() {
    document.getElementById('expenseDetailModal').style.display = 'none';
}

// Show Expense Attachments Modal
async function showExpenseAttachments(expenseId) {
    const modal = document.getElementById('attachmentsModal');
    const content = document.getElementById('attachments-content');
    
    modal.style.display = 'block';
    content.innerHTML = '<p style="text-align: center; color: #888;">Loading attachments...</p>';

    try {
        const response = await API.get(`/expense-attachments/${expenseId}/attachments`);
        
        if (response.data && response.data.length > 0) {
            let html = '<div class="attachments-grid">';
            
            response.data.forEach(attachment => {
                const isImage = attachment.file_type && attachment.file_type.startsWith('image/');
                const fileUrl = attachment.file_path;
                
                html += `
                    <div class="attachment-card">
                        <div class="attachment-preview">
                            ${isImage 
                                ? `<img src="${fileUrl}" alt="${attachment.file_name}" onclick="window.open('${fileUrl}', '_blank')">`
                                : `<i class="fa fa-file-alt"></i>`
                            }
                        </div>
                        <div class="attachment-info">
                            <p class="attachment-name" title="${attachment.file_name}">${attachment.file_name}</p>
                            <p class="attachment-meta">
                                ${formatFileSize(attachment.file_size)} | 
                                ${DateUtils.formatDate(attachment.uploaded_at)}
                            </p>
                            <p class="attachment-uploader">Uploaded by: ${attachment.uploader_name || 'Unknown'}</p>
                        </div>
                        <div class="attachment-actions">
                            <a href="${fileUrl}" target="_blank" class="btn btn-sm btn-view">
                                <i class="fa fa-eye"></i> View
                            </a>
                            <a href="${fileUrl}" download="${attachment.file_name}" class="btn btn-sm btn-export">
                                <i class="fa fa-download"></i> Download
                            </a>
                        </div>
                    </div>
                `;
            });
            
            html += '</div>';
            content.innerHTML = html;
        } else {
            content.innerHTML = '<p style="text-align: center; color: #888;">No attachments found for this expense.</p>';
        }
    } catch (error) {
        console.error('Error fetching attachments:', error);
        content.innerHTML = '<p style="text-align: center; color: red;">Error loading attachments. Please try again.</p>';
    }
}

function closeAttachmentsModal() {
    document.getElementById('attachmentsModal').style.display = 'none';
}

// Show Repair Request Attachments Modal
async function showRepairAttachments(repairRequestId, requestNumber) {
    const modal = document.getElementById('repairAttachmentsModal');
    const content = document.getElementById('repair-attachments-content');
    document.getElementById('repair-request-number').textContent = requestNumber || `#${repairRequestId}`;
    
    modal.style.display = 'block';
    content.innerHTML = '<p style="text-align: center; color: #888;">Loading attachments...</p>';

    try {
        const response = await API.get(`/repair-requests/${repairRequestId}/attachments`);
        
        if (response.data && response.data.length > 0) {
            let html = '<div class="attachments-grid">';
            
            response.data.forEach(attachment => {
                const isImage = attachment.file_type && attachment.file_type.startsWith('image/');
                const fileUrl = `/api/repair-requests/${repairRequestId}/attachments/${attachment.id}/download`;
                
                html += `
                    <div class="attachment-card">
                        <div class="attachment-preview">
                            ${isImage 
                                ? `<img src="${fileUrl}" alt="${attachment.file_name}" onclick="window.open('${fileUrl}', '_blank')">`
                                : `<i class="fa fa-file-pdf-o" style="font-size: 48px; color: #dc3545;"></i>`
                            }
                        </div>
                        <div class="attachment-info">
                            <p class="attachment-name" title="${window.escapeHtml(attachment.original_name || attachment.file_name)}">${window.escapeHtml(attachment.original_name || attachment.file_name)}</p>
                            <p class="attachment-meta">
                                <span class="attachment-type-badge">${window.escapeHtml(attachment.attachment_type || 'Document')}</span>
                                ${formatFileSize(attachment.file_size)}
                            </p>
                            <p class="attachment-uploader">${attachment.uploader_name ? 'By: ' + window.escapeHtml(attachment.uploader_name) : ''}</p>
                        </div>
                        <div class="attachment-actions">
                            <a href="${fileUrl}" target="_blank" class="btn btn-sm btn-info">
                                <i class="fa fa-eye"></i> View
                            </a>
                            <a href="${fileUrl}" download class="btn btn-sm btn-success">
                                <i class="fa fa-download"></i> Download
                            </a>
                        </div>
                    </div>
                `;
            });
            
            html += '</div>';
            content.innerHTML = html;
        } else {
            content.innerHTML = '<p style="text-align: center; color: #888;">No attachments found for this repair request.</p>';
        }
    } catch (error) {
        console.error('Error fetching repair attachments:', error);
        content.innerHTML = '<p style="text-align: center; color: red;">Error loading attachments. Please try again.</p>';
    }
}

function closeRepairAttachmentsModal() {
    document.getElementById('repairAttachmentsModal').style.display = 'none';
}

function formatFileSize(bytes) {
    if (!bytes) return '0 B';
    const k = 1024;
    const sizes = ['B', 'KB', 'MB', 'GB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
}

// Close modals when clicking outside
window.onclick = function(event) {
    const modals = ['expenseHistoryModal', 'expenseDetailModal', 'attachmentsModal', 'repairAttachmentsModal'];
    modals.forEach(modalId => {
        const modal = document.getElementById(modalId);
        if (event.target === modal) {
            modal.style.display = 'none';
        }
    });
};
</script>

