<%- include('partials/header', { pageTitle: 'Create Asset', cssFile: 'assets' }) %>
<!-- Select2 CSS -->
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<%- include('partials/navbar') %>

<div class="main">
    <%- include('partials/sidebar') %>
    <section class="content-area">
        <div class="form-container">
            <h2>Create New Asset</h2>
            <form id="assetForm">
                <div class="form-field">
                    <label for="asset_tag">Asset Tag</label>
                    <input type="text" id="asset_tag" required>
                </div>
                <div class="form-field">
                    <label for="asset_type">Asset Type</label>
                    <select id="asset_type" class="select2-dropdown" required style="width: 100%;">
                        <option value="">-- Select type --</option>
                        <% assetTypes.forEach(function(type) { %>
                            <option value="<%= type.id %>"><%= type.name %></option>
                        <% }); %>
                    </select>
                </div>
                <div class="form-field">
                    <label for="manufacturer">Manufacturer</label>
                    <input type="text" id="manufacturer" required>
                </div>

                <div class="form-field">
                    <label for="model">Model</label>
                    <input type="text" id="model" required>
                </div>
                <div class="form-field">
                    <label for="serial_number">Serial Number</label>
                    <input type="text" id="serial_number" required>
                </div>
                <div class="form-field">
                    <label for="status">Status</label>
                    <select id="status" class="select2-dropdown" required style="width: 100%;">
                        <option value="">-- Select status --</option>
                        <% assetStatuses.forEach(function(status) { %>
                            <option value="<%= status.id %>"><%= status.name %></option>
                        <% }); %>
                    </select>
                </div>

                <div class="form-field">
                    <label for="branch_id">Location</label>
                    <select id="branch_id" class="select2-dropdown" required style="width: 100%;">
                        <option value="">-- Select location --</option>
                        <% branches.forEach(function(branch) { %>
                            <option value="<%= branch.id %>"><%= branch.name %></option>
                        <% }); %>
                    </select>
                </div>
                <div class="form-field">
                    <label for="purchase_date">Purchase Date</label>
                    <input type="date" id="purchase_date" required>
                    <script>
                        // Set max date to today in user's timezone
                        document.getElementById('purchase_date').setAttribute('max', DateUtils.getTodayForInput());
                    </script>
                </div>
                <div class="form-field">
                    <label for="purchase_price">Purchase Price</label>
                    <input type="number" step="0.01" id="purchase_price" required>
                </div>

                <div class="form-field full-width">
                    <label for="notes">Notes</label>
                    <textarea id="notes" rows="3"></textarea>
                </div>

                <div class="form-buttons full-width">
                    <button type="submit" class="btn btn-save">Save Asset</button>
                    <button type="reset" class="btn btn-cancel">Cancel</button>
                </div>
            </form>
        </div>
    </section>
</div>

<!-- jQuery (required for Select2) -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<!-- Select2 JS -->
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script>
$(document).ready(function() {
    $('.select2-dropdown').select2({
        placeholder: 'Type to search...',
        allowClear: true,
        width: 'style',
        minimumResultsForSearch: 0
    });
});
</script>

<%- include('partials/footer', { jsFile: 'assets' }) %>